{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "envId": "your-cloudbase-env-id",
  "appid": "your-miniapp-appid",
  "miniprogramRoot": "miniapp/",
  "cloudfunctionRoot": "miniapp/cloudfunctions/",
  "functionRoot": "miniapp/cloudfunctions/",
  "functions": [
    {
      "name": "adminApi",
      "timeout": 60,
      "memorySize": 512,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {}
    },
    {
      "name": "contentApi",
      "timeout": 20,
      "memorySize": 256,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {}
    },
    {
      "name": "growthApi",
      "timeout": 60,
      "memorySize": 512,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {}
    },
    {
      "name": "commerceApi",
      "timeout": 20,
      "memorySize": 256,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {}
    },
    {
      "name": "opsApi",
      "timeout": 20,
      "memorySize": 256,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {}
    },
    {
      "name": "payApi",
      "timeout": 30,
      "memorySize": 512,
