# CloudBase environment ID used by the admin web app.
# Keep VITE_CLOUDBASE_ENV for the current code path and expose ENV_ID as the
# preferred deployment-facing alias.
VITE_CLOUDBASE_ENV_ID=your-env-id
VITE_CLOUDBASE_ENV=your-env-id
VITE_CLOUDBASE_REGION=ap-shanghai
VITE_CLOUDBASE_PUBLISHABLE_KEY=your-publishable-key
