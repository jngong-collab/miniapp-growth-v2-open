/* pages/package-usage/package-usage.wxss */

.page-package {
  background: var(--bg-page);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ---------- Tab ---------- */
.pkg-tabs {
  display: flex;
  background: var(--bg-card);
  padding: 0 var(--spacing-md);
  border-bottom: 1rpx solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 100;
}

.pkg-tab {
  flex: 1;
  text-align: center;
  padding: var(--spacing-md) 0;
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  position: relative;
  font-weight: 500;
}

.pkg-tab.active {
  color: var(--color-text-title);
  font-weight: 700;
}

.pkg-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  right: 25%;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* ---------- 套餐列表 ---------- */
.pkg-list { padding: var(--spacing-md); }

.pkg-item {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
  transition: opacity 0.2s;
}

.pkg-item.pkg-used { opacity: 0.55; }

.pkg-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.pkg-item-type {
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

.tag-service { background: var(--color-eco-bg); color: var(--color-eco-dark); }
.tag-package { background: var(--color-primary-bg); color: var(--color-primary-dark); }

.pkg-status {
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

.pkg-item-name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-title);
  display: block;
  margin-bottom: var(--spacing-md);
}

/* ---------- 剩余次数 ---------- */
.pkg-remaining {
  background: var(--bg-page);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid var(--color-border);
}

.remaining-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.remaining-name {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  width: 120rpx;
  flex-shrink: 0;
}

.remaining-dots {
  display: flex;
  gap: 8rpx;
  flex: 1;
}

.dot-circle {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.dot-circle.filled { background: var(--color-primary); }
.dot-circle.empty { background: var(--color-border); }

.remaining-count {
  font-size: var(--font-xs);
  color: var(--color-primary-dark);
  font-weight: 600;
  flex-shrink: 0;
  margin-left: var(--spacing-xs);
}

/* ---------- 套餐底部 ---------- */
.pkg-item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid var(--color-border);
  padding-top: var(--spacing-md);
}

.pkg-code {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  font-family: monospace;
}

.show-qr-btn { flex-shrink: 0; }

/* ---------- 核销码展示 ---------- */
.qr-display {
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  width: 100%;
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-lg);
}

.qr-header {
  text-align: center;
  margin-bottom: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}

.qr-product-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-title);
}

.qr-status-tag {
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-capsule);
}

.qr-code-wrap {
  width: 520rpx;
  height: 520rpx;
  background: var(--bg-page);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  padding: var(--spacing-md);
}

.verify-canvas {
  width: 300px;
  height: 300px;
}

/* ---------- 服务选择 ---------- */
.service-selector {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.selector-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.selector-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-title);
}

.selector-btn {
  font-size: var(--font-sm);
  color: var(--color-primary-dark);
  font-weight: 600;
  padding: var(--spacing-xs) var(--spacing-md);
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
}

/* ---------- 剩余信息 ---------- */
.qr-remaining {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-lg);
  width: 100%;
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.qr-remaining .remaining-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.ri-name {
  font-size: var(--font-sm);
  color: var(--color-text-main);
}

.remaining-count-highlight {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-primary-dark);
}

.remaining-count-highlight.exhausted { color: var(--color-text-sub); }

.qr-tip {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  background: var(--bg-page);
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
  width: 100%;
  text-align: center;
  line-height: 1.7;
  border: 1rpx solid var(--color-border);
}

/* ---------- 服务选择弹窗 ---------- */
.service-picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.service-picker {
  background: var(--bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--spacing-lg);
  padding-bottom: calc(env(safe-area-inset-bottom) + var(--spacing-lg));
  width: 100%;
}

.picker-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-title);
  text-align: center;
  margin-bottom: var(--spacing-md);
}

.picker-list { margin-bottom: var(--spacing-md); }

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-xs);
  background: var(--bg-page);
  border: 1rpx solid var(--color-border);
}

.picker-item:active:not(.disabled) { background: var(--color-primary-bg); }
.picker-item.disabled { opacity: 0.4; }

.picker-item-name {
  font-size: var(--font-base);
  color: var(--color-text-title);
  font-weight: 600;
}

.picker-item-count {
  font-size: var(--font-sm);
  color: var(--color-primary-dark);
  font-weight: 600;
}

.picker-cancel {
  text-align: center;
  font-size: var(--font-base);
  color: var(--color-text-sub);
  padding: var(--spacing-md);
}
