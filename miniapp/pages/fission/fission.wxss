/* pages/fission/fission.wxss — 统一风格重设计 */

.page-fission {
  min-height: 100vh;
  background: var(--bg-page);
}

/* ====== 顶部大图 ====== */
.cover-wrap {
  position: relative;
  width: 100%;
  height: 440rpx;
  overflow: hidden;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-gradient {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
}
.cover-info {
  position: absolute;
  bottom: 32rpx; left: 32rpx;
  z-index: 2;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.cover-badge {
  align-self: flex-start;
  padding: 6rpx 20rpx;
  background: rgba(192, 139, 92, 0.9);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.cover-name {
  font-size: 40rpx;
  font-weight: 900;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 1rpx;
}

/* ====== 内容区 ====== */
.content-area {
  padding: 24rpx 28rpx 60rpx;
  margin-top: -24rpx;
  position: relative;
  z-index: 1;
}

/* ====== 价格卡片 ====== */
.price-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
}
.price-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.price-tip {
  font-size: 22rpx;
  color: var(--color-text-sub);
  font-weight: 600;
}
.price-row {
  display: flex;
  align-items: baseline;
  color: var(--color-primary);
}
.yen { font-size: 28rpx; font-weight: 800; }
.price-big { font-size: 56rpx; font-weight: 900; letter-spacing: -2rpx; }
.cashback-color { color: #F5A623; }
.price-orig {
  font-size: 22rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
}
.price-sub {
  font-size: 22rpx;
  color: var(--color-text-sub);
}
.price-divider {
  width: 1rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.08), transparent);
  margin: 0 16rpx;
}

/* ====== 进度条 ====== */
.progress-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.progress-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-sub);
  margin-bottom: 12rpx;
}
.progress-track {
  height: 12rpx;
  background: #EDE5DC;
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), #D4A574);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* ====== 购买按钮 ====== */
.buy-btn {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
  padding: 28rpx;
  border-radius: 20rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(192, 139, 92, 0.25);
  transition: transform 0.2s ease;
}
.buy-btn:active {
  transform: scale(0.97);
}

/* ====== 通用信息卡 ====== */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.info-head {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--color-text-title);
  margin-bottom: 20rpx;
}

/* 标签组 */
.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.tag {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}
.tag-green { background: #EFFFF8; color: #059669; }
.tag-blue { background: #EFF6FF; color: #2563EB; }

.info-text {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--color-text-sub);
  display: block;
}

/* ====== 推荐步骤 ====== */
.steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.step-num {
  width: 40rpx; height: 40rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx; font-weight: 700;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 10rpx;
}
.step-emoji { font-size: 48rpx; margin-bottom: 8rpx; }
.step-text { font-size: 22rpx; color: var(--color-text-sub); text-align: center; font-weight: 500; }
.step-arrow { font-size: 28rpx; color: var(--color-text-muted); flex-shrink: 0; margin: 0 4rpx; }

/* ====== 收益 ====== */
.earn-row {
  display: flex;
}
.earn-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.earn-val {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--color-text-title);
}
.earn-val.coral { color: var(--color-primary); }
.earn-label {
  font-size: 22rpx;
  color: var(--color-text-sub);
}

/* ====== 邀请记录 ====== */
.record {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.record:last-child { border-bottom: none; }
.record-left { display: flex; align-items: center; }
.record-avatar {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: #EDE5DC;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  overflow: hidden;
}
.record-meta { margin-left: 16rpx; display: flex; flex-direction: column; gap: 4rpx; }
.record-name { font-size: 28rpx; color: var(--color-text-title); font-weight: 600; }
.record-time { font-size: 22rpx; color: var(--color-text-muted); }
.record-amount { font-size: 30rpx; font-weight: 800; color: #52C41A; }

/* ====== 活动规则 ====== */
.rules-card {
  background: #FFFBE6;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}
.rules-head {
  font-size: 26rpx;
  font-weight: 700;
  color: #8B6914;
  margin-bottom: 16rpx;
}
.rules-item {
  display: block;
  font-size: 24rpx;
  color: #AD6800;
  line-height: 2;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx;
}
.empty-emoji { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: var(--color-text-title); font-weight: 700; margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: var(--color-text-sub); }
