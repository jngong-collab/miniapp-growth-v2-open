/* pages/fission/fission.wxss — 统一风格重设计 */

.page-fission {
  min-height: 100vh;
  background: var(--bg-page);
}

/* ====== 顶部大图 ====== */
.cover-wrap {
  position: relative;
  width: 100%;
  height: 440rpx;
  overflow: hidden;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-gradient {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
}
.cover-info {
  position: absolute;
  bottom: var(--spacing-lg); left: var(--spacing-lg);
  z-index: 2;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}
.cover-badge {
  align-self: flex-start;
  padding: 6rpx var(--spacing-md);
  background: var(--color-primary);
  border-radius: var(--radius-capsule);
  font-size: var(--font-xs);
  font-weight: 700;
}
.cover-name {
  font-size: var(--font-xl);
  font-weight: 900;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 1rpx;
}

/* ====== 内容区 ====== */
.content-area {
  padding: var(--spacing-md) var(--spacing-md) 60rpx;
  margin-top: calc(-1 * var(--spacing-md));
  position: relative;
  z-index: 1;
}

/* ====== 价格卡片 ====== */
.price-card {
  display: flex;
  align-items: center;
  background: linear-gradient(165deg, var(--bg-card) 0%, #FFFFFF 78%, var(--color-bg-white) 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg) var(--spacing-md);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-md);
}
.price-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}
.price-tip {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  font-weight: 600;
}
.price-row {
  display: flex;
  align-items: baseline;
  color: var(--color-primary);
}
.yen { font-size: var(--font-base); font-weight: 800; }
.price-big { font-size: 56rpx; font-weight: 900; letter-spacing: -2rpx; }
.cashback-color { color: var(--color-warning, var(--color-gold)); }
.price-orig {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  text-decoration: line-through;
}
.price-sub {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}
.price-divider {
  width: 1rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.08), transparent);
  margin: 0 var(--spacing-sm);
}

/* ====== 进度条 ====== */
.progress-section {
  background: linear-gradient(165deg, var(--bg-card) 0%, #FFFFFF 78%, var(--color-bg-white) 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  border: 1rpx solid var(--color-border);
}
.progress-meta {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  margin-bottom: var(--spacing-xs);
}
.progress-track {
  height: 12rpx;
  background: var(--color-primary-bg);
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
  border-radius: var(--radius-sm);
  transition: width 0.5s ease;
}

/* ====== 购买按钮 ====== */
.buy-btn {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  font-size: var(--font-md);
  font-weight: 800;
  text-align: center;
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-lg);
  box-shadow: 0 12rpx 28rpx rgba(192, 139, 92, 0.25);
  transition: transform 0.2s ease;
}
.buy-btn:active {
  transform: scale(0.97);
}

/* ====== 通用信息卡 ====== */
.info-card {
  background: linear-gradient(165deg, var(--bg-card) 0%, #FFFFFF 78%, var(--color-bg-white) 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  border: 1rpx solid var(--color-border);
}
.info-head {
  font-size: var(--font-md);
  font-weight: 800;
  color: var(--color-text-title);
  margin-bottom: var(--spacing-md);
}

/* 标签组 */
.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}
.tag {
  display: inline-block;
  font-size: var(--font-sm);
  font-weight: 600;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-sm);
}
.tag-green { background: var(--color-eco-bg); color: var(--color-eco); }
.tag-blue { background: var(--color-ai-bg); color: var(--color-ai); }

.info-text {
  font-size: var(--font-sm);
  line-height: 1.8;
  color: var(--color-text-sub);
  display: block;
}

/* ====== 推荐步骤 ====== */
.steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.step-num {
  width: 40rpx; height: 40rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-xs); font-weight: 700;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: var(--spacing-xs);
}
.step-emoji { font-size: var(--font-xl); margin-bottom: var(--spacing-xs); }
.step-text { font-size: var(--font-xs); color: var(--color-text-sub); text-align: center; font-weight: 500; }
.step-arrow { font-size: var(--font-base); color: var(--color-text-muted); flex-shrink: 0; margin: 0 4rpx; }

/* ====== 收益 ====== */
.earn-row {
  display: flex;
}
.earn-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}
.earn-val {
  font-size: var(--font-lg);
  font-weight: 900;
  color: var(--color-text-title);
}
.earn-val.coral { color: var(--color-primary); }
.earn-label {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}

/* ====== 邀请记录 ====== */
.record {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.record:last-child { border-bottom: none; }
.record-left { display: flex; align-items: center; }
.record-avatar {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-base);
  overflow: hidden;
}
.record-meta { margin-left: var(--spacing-sm); display: flex; flex-direction: column; gap: var(--spacing-xs); }
.record-name { font-size: var(--font-base); color: var(--color-text-title); font-weight: 600; }
.record-time { font-size: var(--font-xs); color: var(--color-text-muted); }
.record-amount { font-size: var(--font-md); font-weight: 800; color: var(--color-eco); }

/* ====== 活动规则 ====== */
.rules-card {
  background: linear-gradient(165deg, var(--bg-card) 0%, #FFFFFF 78%, var(--color-bg-white) 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}
.rules-head {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-primary-dark);
  margin-bottom: var(--spacing-sm);
}
.rules-item {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  line-height: 2;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx var(--spacing-xl);
}
.empty-emoji { font-size: 100rpx; margin-bottom: var(--spacing-md); }
.empty-title { font-size: var(--font-md); color: var(--color-text-title); font-weight: 700; margin-bottom: var(--spacing-xs); }
.empty-hint { font-size: var(--font-sm); color: var(--color-text-sub); }
