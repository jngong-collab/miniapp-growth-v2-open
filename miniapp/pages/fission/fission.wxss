/* pages/fission/fission.wxss — 现代东方裂变活动 */

.page-fission {
  min-height: 100vh;
  background: var(--bg-page);
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 420rpx;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-gradient {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
}

.cover-info {
  position: absolute;
  bottom: var(--spacing-lg); left: var(--spacing-lg);
  z-index: 2;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.cover-badge {
  align-self: flex-start;
  padding: 4rpx 14rpx;
  background: var(--color-primary);
  border-radius: var(--radius-capsule);
  font-size: var(--font-xs);
  font-weight: 600;
}

.cover-name {
  font-size: var(--font-xl);
  font-weight: 800;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 0.5rpx;
}

.content-area {
  padding: var(--spacing-md) var(--spacing-lg) 80rpx;
  margin-top: calc(-1 * var(--spacing-md));
  position: relative;
  z-index: 1;
}

/* 价格卡片 */
.price-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg) var(--spacing-md);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-md);
}

.price-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}

.price-tip {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  font-weight: 500;
}

.price-row {
  display: flex;
  align-items: baseline;
  color: var(--color-primary-dark);
}

.yen { font-size: var(--font-sm); font-weight: 700; }
.price-big { font-size: 52rpx; font-weight: 800; letter-spacing: -2rpx; }
.cashback-color { color: var(--color-gold); }

.price-orig {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  text-decoration: line-through;
}

.price-sub {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}

.price-divider {
  width: 1rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, transparent, var(--color-border), transparent);
  margin: 0 var(--spacing-sm);
}

/* 进度条 */
.progress-section {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.progress-meta {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  margin-bottom: var(--spacing-xs);
}

.progress-track {
  height: 10rpx;
  background: var(--color-primary-bg);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
  border-radius: 5rpx;
  transition: width 0.5s ease;
}

/* 购买按钮 */
.buy-btn {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  font-size: var(--font-md);
  font-weight: 700;
  text-align: center;
  padding: var(--spacing-md);
  border-radius: var(--radius-capsule);
  margin-bottom: var(--spacing-lg);
  box-shadow: 0 12rpx 28rpx rgba(184,145,107,0.2);
  transition: transform 0.2s ease;
}

.buy-btn:active { transform: scale(0.97); }

/* 通用信息卡 */
.info-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.info-head {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-title);
  margin-bottom: var(--spacing-md);
}

.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}

.info-text {
  font-size: var(--font-sm);
  line-height: 1.8;
  color: var(--color-text-sub);
  display: block;
}

/* 推荐步骤 */
.steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-num {
  width: 36rpx; height: 36rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary-dark);
  font-size: var(--font-xs); font-weight: 700;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: var(--spacing-xs);
}

.step-emoji { font-size: var(--font-lg); margin-bottom: var(--spacing-xs); }
.step-text { font-size: var(--font-xs); color: var(--color-text-sub); text-align: center; font-weight: 500; }

.step-line-h {
  width: 24rpx;
  height: 1rpx;
  background: var(--color-border);
  flex-shrink: 0;
}

/* 收益 */
.earn-row { display: flex; }
.earn-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}

.earn-val {
  font-size: var(--font-lg);
  font-weight: 800;
  color: var(--color-text-title);
}

.earn-val.earn-gold { color: var(--color-gold); }
.earn-label { font-size: var(--font-xs); color: var(--color-text-sub); }

/* 邀请记录 */
.record {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.record:last-child { border-bottom: none; }
.record-left { display: flex; align-items: center; }

.record-avatar {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-base);
  overflow: hidden;
}

.record-meta { margin-left: var(--spacing-sm); display: flex; flex-direction: column; gap: var(--spacing-xs); }
.record-name { font-size: var(--font-base); color: var(--color-text-title); font-weight: 600; }
.record-time { font-size: var(--font-xs); color: var(--color-text-muted); }
.record-amount { font-size: var(--font-md); font-weight: 800; color: var(--color-eco-dark); }

/* 活动规则 */
.rules-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.rules-head {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-text-title);
  margin-bottom: var(--spacing-sm);
}

.rules-item {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  line-height: 2;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx var(--spacing-xl);
}

.empty-icon { font-size: 80rpx; margin-bottom: var(--spacing-sm); opacity: 0.8; }
.empty-text { font-size: var(--font-md); color: var(--color-text-title); font-weight: 700; margin-bottom: var(--spacing-xs); }
.empty-hint { font-size: var(--font-sm); color: var(--color-text-sub); }
