/* pages/mall/mall.wxss — 高级重构版 */
.page-container {
  min-height: 100vh;
  position: relative;
  background: var(--bg-page);
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部背景装饰 (同首页) */
.bg-decoration {
  position: absolute;
  top: 0; left: 0; right: 0;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.5;
  z-index: 0;
}
.shape-1 {
  position: absolute;
  width: 500rpx; height: 500rpx;
  background: var(--color-ai-bg);
  top: -150rpx; right: -100rpx;
  opacity: 0.8;
}
.shape-2 {
  position: absolute;
  width: 400rpx; height: 400rpx;
  background: var(--color-eco-bg);
  top: 400rpx; left: -150rpx;
  opacity: 0.8;
}

/* 吸顶导航区 */
.mall-sticky-header {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: var(--spacing-md) var(--spacing-lg) var(--spacing-sm);
  background: rgba(250, 246, 241, 0.85); /* 透明毛玻璃 */
  backdrop-filter: blur(20px);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
}

/* 高级搜索栏 */
.search-box {
  margin-bottom: var(--spacing-md);
}
.search-inner {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 var(--spacing-lg);
  background: #FFFFFF;
  border-radius: var(--radius-capsule);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(255,255,255,0.8);
  transition: all 0.3s;
}
.search-inner:focus-within {
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.06);
  border-color: rgba(192, 139, 92, 0.2);
}
.search-icon {
  font-size: var(--font-md);
  margin-right: 16rpx;
}
.search-input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text-title);
  font-weight: 500;
}
.search-ph {
  color: #9CA3AF;
  font-weight: 400;
}

/* 分类标签 (分段器) */
.category-scroll {
  width: 100%;
  white-space: nowrap;
}
.category-capsule {
  display: inline-flex;
  gap: 12rpx;
}
.cat-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-lg);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.cat-text {
  font-size: var(--font-base);
  color: var(--color-text-sub);
  font-weight: 500;
  z-index: 2;
  transition: color 0.3s, transform 0.3s;
}
.cat-line {
  position: absolute;
  bottom: 4rpx;
  width: 0;
  height: 6rpx;
  border-radius: 4rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
  transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(192,139,92,0.3);
}

/* 激活态分类 */
.cat-item.active .cat-text {
  color: var(--color-text-title);
  font-weight: 800;
  transform: scale(1.05); /* 稍微放大 */
}
.cat-item.active .cat-line {
  width: 40rpx;
}

/* 商城主体内容 */
.mall-body {
  position: relative;
  z-index: 1;
  padding: var(--spacing-md) var(--spacing-lg) 120rpx;
}

/* ====== 限时活动焦点图 ====== */
.hero-section {
  margin-bottom: var(--spacing-md);
}
.hero-swiper {
  height: 360rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.hero-card {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
/* 产品大图 */
.hero-prod-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
/* 底部渐变蒙层 */
.hero-gradient {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 70%;
  background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.3) 50%, transparent 100%);
  z-index: 1;
}
/* 浮层信息 */
.hero-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: var(--spacing-md) 28rpx 28rpx;
  z-index: 2;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}
.hero-badge {
  align-self: flex-start;
  padding: 6rpx 18rpx;
  background: rgba(192, 139, 92, 0.85);
  border-radius: var(--radius-capsule);
  font-size: var(--font-sm);
  font-weight: 700;
  letter-spacing: 1rpx;
  backdrop-filter: blur(4px);
}
.hero-prod-name {
  font-size: var(--font-lg);
  font-weight: 900;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 1rpx;
}
/* 价格行 */
.hero-price-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-sm);
}
.hero-current-price {
  display: flex;
  align-items: baseline;
}
.hero-yen {
  font-size: var(--font-base);
  font-weight: 800;
  margin-right: 2rpx;
}
.hero-amount {
  font-size: 52rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.25);
}
.hero-cashback {
  padding: 4rpx var(--spacing-sm);
  background: rgba(255,255,255,0.2);
  border: 1rpx solid rgba(255,255,255,0.3);
  border-radius: var(--radius-capsule);
  font-size: var(--font-sm);
  font-weight: 600;
  backdrop-filter: blur(4px);
}
/* 进度条 */
.hero-progress-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}
.hero-progress-bar {
  flex: 1;
  max-width: 300rpx;
  height: var(--spacing-xs);
  background: rgba(255,255,255,0.2);
  border-radius: 4rpx;
  overflow: hidden;
}
.hero-progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 4rpx;
  transition: width 0.6s ease;
}
.hero-sold-text {
  font-size: var(--font-xs);
  opacity: 0.75;
}

/* 商品列表卡片 */
.prod-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}
.premium-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(255,255,255,0.8);
}
.prod-card {
  display: flex;
  gap: var(--spacing-md);
  transition: transform 0.2s, box-shadow 0.2s;
}
.prod-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

/* 图片区域与微角标 */
.prod-image-zone {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: #F5F0E8;
  flex-shrink: 0;
}
.prod-img {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}
.prod-card:active .prod-img {
  transform: scale(1.05);
}
.type-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 14rpx;
  font-size: var(--font-sm);
  font-weight: 800;
  border-radius: 8rpx;
  backdrop-filter: blur(4px);
  letter-spacing: 1rpx;
}
.badge-eco { background: rgba(123, 175, 142, 0.85); color: #059669; }
.badge-ai { background: rgba(107, 138, 153, 0.85); color: #FFF; }
.badge-primary { background: rgba(192, 139, 92, 0.85); color: #FFF; }

/* 内容描述区 */
.prod-info-zone {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
}
.info-top {
  display: flex;
  flex-direction: column;
}
.prod-title {
  font-size: var(--font-md);
  font-weight: 800;
  color: var(--color-text-title);
  line-height: 1.4;
  margin-bottom: 8rpx;
  /* 限制两行 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.prod-efficacy {
  font-size: var(--font-base);
  color: var(--color-text-sub);
  background: rgba(0,0,0,0.03);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

/* 底部价格与按钮区域 */
.info-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.price-wrap {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-xs);
}
.current-price {
  color: var(--color-primary);
}
.price-symbol {
  font-size: var(--font-sm);
  font-weight: 800;
  margin-right: 2rpx;
}
.price-val {
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}
.origin-price {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  text-decoration: line-through;
}

/* 圆形呼吸按钮 */
.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: #FFF;
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  box-shadow: 0 4rpx 12rpx rgba(192, 139, 92, 0.3);
  transition: all 0.2s;
}
.action-btn:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 4rpx rgba(192, 139, 92, 0.2);
}

/* 返现标签浮标 */
.cashback-strip {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: linear-gradient(90deg, rgba(192,139,92,0.1), rgba(192,139,92,0.05));
  border: 1rpx solid rgba(192,139,92,0.2);
  padding: 4rpx var(--spacing-sm);
  border-radius: var(--radius-sm) 0 var(--radius-sm) var(--radius-sm);
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.cb-icon { font-size: 20rpx; }
.cb-text { font-size: var(--font-sm); color: var(--color-primary); font-weight: 700; }

/* 到底提示状态区 */
.bottom-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0 40rpx;
  gap: var(--spacing-sm);
}
.bottom-tips .line { width: 40rpx; height: 1rpx; background: rgba(0,0,0,0.06); }
.bottom-tips .tips-txt { font-size: var(--font-sm); color: var(--color-text-muted); font-weight: 500; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 100rpx; opacity: 0.6; margin-bottom: 24rpx; }
.empty-text { font-size: var(--font-base); color: var(--color-text-muted); font-weight: 500; }
