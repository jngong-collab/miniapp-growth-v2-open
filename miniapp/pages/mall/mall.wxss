/* pages/mall/mall.wxss — 现代东方商城 */

.page-mall {
  min-height: 100vh;
  position: relative;
  background: var(--bg-page);
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}

.bg-deco {
  position: absolute;
  border-radius: 50%;
  filter: blur(120rpx);
  opacity: 0.4;
  z-index: 0;
  pointer-events: none;
}

.bg-deco-1 {
  width: 500rpx; height: 500rpx;
  background: var(--color-primary-bg);
  top: -150rpx; right: -100rpx;
}

.bg-deco-2 {
  width: 400rpx; height: 400rpx;
  background: var(--color-ai-bg);
  top: 400rpx; left: -150rpx;
}

/* 吸顶导航 */
.mall-sticky-header {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: var(--spacing-md) var(--spacing-lg) var(--spacing-sm);
  background: rgba(250,247,242,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
}

.search-box {
  margin-bottom: var(--spacing-md);
}

.search-inner {
  display: flex;
  align-items: center;
  height: 76rpx;
  padding: 0 var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-capsule);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
  transition: all 0.3s;
}

.search-icon {
  font-size: var(--font-sm);
  margin-right: 12rpx;
  color: var(--color-text-muted);
}

.search-input {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--color-text-title);
  font-weight: 500;
}

.search-ph {
  color: var(--color-text-muted);
  font-weight: 400;
}

/* 分类标签 */
.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-capsule {
  display: inline-flex;
  gap: 12rpx;
}

.cat-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.cat-text {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  font-weight: 500;
  z-index: 2;
  transition: color 0.3s, transform 0.3s;
}

.cat-line {
  position: absolute;
  bottom: 4rpx;
  width: 0;
  height: 4rpx;
  border-radius: 2rpx;
  background: var(--color-primary);
  transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.cat-item.active .cat-text {
  color: var(--color-text-title);
  font-weight: 700;
  transform: scale(1.03);
}

.cat-item.active .cat-line {
  width: 32rpx;
}

/* 商城主体 */
.mall-body {
  position: relative;
  z-index: 1;
  padding: var(--spacing-md) var(--spacing-lg) 120rpx;
}

/* 限时活动焦点图 */
.hero-section {
  margin-bottom: var(--spacing-md);
}

.hero-swiper {
  height: 340rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.hero-card {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.hero-prod-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero-gradient {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 70%;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.25) 50%, transparent 100%);
  z-index: 1;
}

.hero-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: var(--spacing-md) 28rpx 28rpx;
  z-index: 2;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.hero-badge {
  align-self: flex-start;
  padding: 4rpx 12rpx;
  background: var(--color-primary);
  border-radius: var(--radius-capsule);
  font-size: var(--font-xs);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-prod-name {
  font-size: var(--font-lg);
  font-weight: 800;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 0.5rpx;
}

.hero-price-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-sm);
}

.hero-current-price {
  display: flex;
  align-items: baseline;
}

.hero-yen {
  font-size: var(--font-sm);
  font-weight: 700;
  margin-right: 2rpx;
}

.hero-amount {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.25);
}

.hero-cashback {
  padding: 4rpx 12rpx;
  background: rgba(255,255,255,0.18);
  border: 1rpx solid rgba(255,255,255,0.25);
  border-radius: var(--radius-capsule);
  font-size: var(--font-xs);
  font-weight: 600;
}

.hero-progress-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.hero-progress-bar {
  flex: 1;
  max-width: 280rpx;
  height: 6rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 3rpx;
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 3rpx;
  transition: width 0.6s ease;
}

.hero-sold-text {
  font-size: var(--font-xs);
  opacity: 0.8;
}

/* 商品列表卡片 */
.prod-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.prod-card {
  display: flex;
  gap: var(--spacing-md);
  background: var(--bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s, box-shadow 0.2s;
}

.prod-card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-sm);
}

/* 图片区域 */
.prod-image-zone {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--bg-page);
  flex-shrink: 0;
}

.prod-img {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.prod-card:active .prod-img {
  transform: scale(1.04);
}

.type-badge {
  position: absolute;
  top: var(--spacing-sm);
  left: var(--spacing-sm);
  padding: 4rpx 10rpx;
  font-size: var(--font-xs);
  font-weight: 600;
  border-radius: var(--radius-sm);
  backdrop-filter: blur(4px);
}

.badge-eco { background: var(--color-eco-bg); color: var(--color-eco-dark); }
.badge-ai { background: var(--color-ai-bg); color: #fff; }
.badge-primary { background: var(--color-primary-bg); color: var(--color-primary-dark); }

/* 内容描述区 */
.prod-info-zone {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
}

.info-top {
  display: flex;
  flex-direction: column;
}

.prod-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-title);
  line-height: 1.4;
  margin-bottom: var(--spacing-xs);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.prod-efficacy {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  background: var(--bg-page);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
  align-self: flex-start;
}

/* 底部价格与按钮 */
.info-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: var(--spacing-xs);
}

.price-wrap {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-xs);
}

.current-price {
  color: var(--color-primary-dark);
}

.price-symbol {
  font-size: var(--font-xs);
  font-weight: 700;
  margin-right: 2rpx;
}

.price-val {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.origin-price {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  text-decoration: line-through;
}

.action-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: #fff;
  background: var(--color-primary);
  box-shadow: 0 4rpx 12rpx rgba(184,145,107,0.22);
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.9);
}

/* 返现标签 */
.cashback-strip {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: linear-gradient(90deg, rgba(184,145,107,0.1), rgba(184,145,107,0.04));
  border: 1rpx solid rgba(184,145,107,0.18);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm) 0 var(--radius-sm) var(--radius-sm);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.cb-icon { font-size: var(--font-xs); }
.cb-text { font-size: var(--font-xs); color: var(--color-primary-dark); font-weight: 600; }

/* 到底提示 */
.bottom-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0 var(--spacing-xl);
  gap: var(--spacing-sm);
}

.bottom-tips .line { width: 40rpx; height: 1rpx; background: var(--color-border); }
.bottom-tips .tips-txt { font-size: var(--font-xs); color: var(--color-text-muted); font-weight: 500; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 80rpx; opacity: 0.7; margin-bottom: var(--spacing-sm); }
.empty-text { font-size: var(--font-base); color: var(--color-text-sub); font-weight: 600; }
