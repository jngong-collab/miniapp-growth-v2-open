<!--pages/mall/mall.wxml-->
<view class="page-mall">
  <view class="bg-deco bg-deco-1"></view>
  <view class="bg-deco bg-deco-2"></view>

  <!-- 吸顶导航 -->
  <view class="mall-sticky-header">
    <view class="search-box">
      <view class="search-inner">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索服务、调理套餐…" placeholder-class="search-ph" bindinput="onSearch" value="{{keyword}}" />
      </view>
    </view>

    <scroll-view class="category-scroll" scroll-x enable-flex enhanced show-scrollbar="{{false}}">
      <view class="category-capsule">
        <view class="cat-item {{activeTab === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" bindtap="switchTab" data-tab="{{item}}">
          <text class="cat-text">{{item}}</text>
          <view class="cat-line"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="mall-body">
    <!-- 限时活动轮播 -->
    <view class="hero-section animate-fade-up" style="animation-delay: 0.05s" wx:if="{{fissionCampaigns.length > 0}}">
      <swiper class="hero-swiper" indicator-dots="{{fissionCampaigns.length > 1}}" indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#fff" autoplay circular interval="{{4000}}">
        <swiper-item wx:for="{{fissionCampaigns}}" wx:key="_id">
          <view class="hero-card card-press" bindtap="goToFission">
            <view class="hero-gradient"></view>
            <image class="hero-prod-img" src="{{item.productImage}}" mode="aspectFill" wx:if="{{item.productImage}}"></image>
            <view class="hero-overlay">
              <view class="hero-badge">限时活动</view>
              <text class="hero-prod-name">{{item.productName}}</text>
              <view class="hero-price-row">
                <view class="hero-current-price">
                  <text class="hero-yen">¥</text>
                  <text class="hero-amount">{{item.activityPriceYuan}}</text>
                </view>
                <view class="hero-cashback">
                  <text>推荐返 ¥{{item.cashbackAmountYuan}}/单</text>
                </view>
              </view>
              <view class="hero-progress-wrap" wx:if="{{item.soldPercent > 0}}">
                <view class="hero-progress-bar">
                  <view class="hero-progress-fill" style="width: {{item.soldPercent}}%"></view>
                </view>
                <text class="hero-sold-text">已参与 {{item.soldCount || 0}} 人</text>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 商品列表 -->
    <view class="prod-list">
      <view class="prod-card animate-fade-up" wx:for="{{products}}" wx:key="_id" bindtap="goToProduct" data-id="{{item._id}}" style="animation-delay: {{index * 0.06}}s">
        <view class="prod-image-zone">
          <image class="prod-img" src="{{item.images[0]}}" mode="aspectFill"></image>
          <view class="type-badge {{item.type === 'service' ? 'badge-eco' : item.type === 'package' ? 'badge-ai' : 'badge-primary'}}">
            {{item.type === 'service' ? '服务' : item.type === 'package' ? '套餐' : '产品'}}
          </view>
        </view>

        <view class="prod-info-zone">
          <view class="info-top">
            <text class="prod-title">{{item.name}}</text>
            <text class="prod-efficacy" wx:if="{{item.efficacy}}">{{item.efficacy}}</text>
          </view>

          <view class="info-bottom">
            <view class="price-wrap">
              <view class="current-price">
                <text class="price-symbol">¥</text>
                <text class="price-val">{{item.priceYuan}}</text>
              </view>
              <text class="origin-price" wx:if="{{item.originalPriceYuan && item.originalPriceYuan !== '0.0'}}">¥{{item.originalPriceYuan}}</text>
            </view>
            <view class="action-btn card-press">＋</view>
          </view>

          <view class="cashback-strip" wx:if="{{item.hasCashback}}">
            <text class="cb-icon">🧧</text>
            <text class="cb-text">返 ¥{{item.cashbackAmountYuan}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底线提示 -->
    <view class="bottom-tips" wx:if="{{!hasMore && products.length > 0}}">
      <text class="line"></text>
      <text class="tips-txt">已经到底啦</text>
      <text class="line"></text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
      <view class="empty-icon">🍃</view>
      <text class="empty-text">暂无相关商品</text>
    </view>
  </view>
</view>
