/* pages/workbench/settings/settings.wxss */

.simple-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.list-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-sm);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-xs);
}

.list-title {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-text-title);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.list-tag {
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  margin-left: var(--spacing-sm);
}

.tag-eco { background: var(--color-eco-bg); color: var(--color-eco-dark); }
.tag-ai { background: var(--color-ai-bg); color: var(--color-ai); }
.tag-primary { background: var(--color-primary-bg); color: var(--color-primary-dark); }

.list-desc {
  display: block;
  margin-top: 4rpx;
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}

.staff-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.staff-item {
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border);
  margin-top: var(--spacing-sm);
}

.staff-item:first-of-type {
  border-top: none;
  margin-top: 0;
}

.staff-name {
  display: block;
  color: var(--color-text-title);
  font-size: var(--font-sm);
  font-weight: 600;
}

.staff-desc {
  display: block;
  margin-top: 2rpx;
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}

.staff-empty {
  padding-top: var(--spacing-sm);
}

.action-btn {
  margin: 0;
  border-radius: var(--radius-capsule);
  background: var(--color-text-title);
  color: #fff;
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 0 14rpx;
  height: 48rpx;
  line-height: 46rpx;
}

.empty-block {
  padding: 160rpx var(--spacing-lg);
  text-align: center;
}

.empty-title {
  color: var(--color-text-sub);
  font-size: var(--font-base);
  font-weight: 600;
}
