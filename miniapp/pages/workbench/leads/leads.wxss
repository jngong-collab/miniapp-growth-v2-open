/* pages/workbench/leads/leads.wxss */

.leads-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.filter-scroll {
  white-space: nowrap;
  margin-bottom: var(--spacing-md);
}

.filter-row {
  display: inline-flex;
  gap: var(--spacing-sm);
}

.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-capsule);
  background: var(--bg-card);
  color: var(--color-text-sub);
  font-size: var(--font-sm);
  border: 1rpx solid var(--color-border);
}

.filter-chip-active {
  background: var(--color-ai);
  color: #fff;
  border-color: var(--color-ai);
}

.lead-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-md);
}

.lead-top {
  display: flex;
  justify-content: space-between;
  gap: var(--spacing-md);
}

.lead-name {
  display: block;
  color: var(--color-text-title);
  font-size: var(--font-base);
  font-weight: 700;
}

.lead-source,
.lead-note {
  display: block;
  margin-top: 4rpx;
  color: var(--color-text-sub);
  font-size: var(--font-xs);
}

.lead-status {
  height: fit-content;
  padding: 6rpx 12rpx;
  border-radius: var(--radius-capsule);
  background: var(--color-ai-bg);
  color: var(--color-ai);
  font-size: var(--font-xs);
  font-weight: 600;
  flex-shrink: 0;
}

.lead-track {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-md);
}

.track-pill {
  padding: 6rpx 12rpx;
  border-radius: var(--radius-capsule);
  background: var(--color-eco-bg);
  color: var(--color-eco-dark);
  font-size: var(--font-xs);
}

.action-btn {
  margin: var(--spacing-md) 0 0;
  border-radius: var(--radius-capsule);
  background: var(--color-text-title);
  color: #fff;
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 0 16rpx;
  height: 48rpx;
  line-height: 46rpx;
}

.empty-block {
  padding: 160rpx var(--spacing-lg);
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-sm);
  display: block;
}

.empty-title {
  color: var(--color-text-sub);
  font-size: var(--font-base);
  font-weight: 600;
}
