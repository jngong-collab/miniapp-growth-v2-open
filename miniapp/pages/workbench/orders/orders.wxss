/* pages/workbench/orders/orders.wxss */

.workbench-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.filter-scroll {
  white-space: nowrap;
  margin-bottom: var(--spacing-md);
}

.filter-row {
  display: inline-flex;
  gap: var(--spacing-sm);
}

.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-capsule);
  background: var(--bg-card);
  color: var(--color-text-sub);
  font-size: var(--font-sm);
  border: 1rpx solid var(--color-border);
}

.filter-chip-active {
  background: var(--color-text-title);
  color: #fff;
  border-color: var(--color-text-title);
}

.list-wrap {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.list-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.card-top,
.meta-row {
  display: flex;
  justify-content: space-between;
  gap: var(--spacing-md);
}

.card-title {
  display: block;
  font-size: var(--font-base);
  color: var(--color-text-title);
  font-weight: 700;
}

.card-sub,
.meta-row,
.refund-sub {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}

.card-sub,
.meta-row {
  display: block;
  margin-top: 4rpx;
}

.meta-highlight {
  color: var(--color-primary-dark);
  font-weight: 600;
}

.tag {
  height: fit-content;
  padding: 6rpx 12rpx;
  background: var(--color-primary-bg);
  border-radius: var(--radius-capsule);
  color: var(--color-primary-dark);
  font-size: var(--font-xs);
  font-weight: 600;
  flex-shrink: 0;
}

.refund-box {
  margin-top: var(--spacing-md);
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  background: var(--bg-page);
  border: 1rpx solid var(--color-border);
}

.refund-title {
  display: block;
  color: var(--color-text-title);
  font-size: var(--font-sm);
  font-weight: 600;
}

.action-btn {
  margin: var(--spacing-sm) 0 0;
  border-radius: var(--radius-capsule);
  background: var(--color-text-title);
  color: #fff;
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 0 16rpx;
  height: 48rpx;
  line-height: 46rpx;
}

.empty-block {
  padding: 160rpx var(--spacing-lg);
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-sm);
  display: block;
}

.empty-title {
  color: var(--color-text-sub);
  font-size: var(--font-base);
  font-weight: 600;
}
