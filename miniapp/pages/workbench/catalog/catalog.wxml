<view class="simple-page">
  <view class="summary-row">
    <view class="summary-card animate-fade-up" style="animation-delay:0s">
      <text class="summary-value">{{overview.products.length}}</text>
      <text class="summary-label">商品主目录</text>
    </view>
    <view class="summary-card animate-fade-up" style="animation-delay:0.05s">
      <text class="summary-value">{{overview.packages.length}}</text>
      <text class="summary-label">兼容套餐模板</text>
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">商品列表</text>
    <text class="section-subtitle">PRODUCTS</text>
  </view>
  <view class="list-card animate-fade-up" wx:for="{{overview.products}}" wx:key="_id" style="animation-delay:{{0.1 + index*0.04}}s">
    <text class="list-title">{{item.name}}</text>
    <text class="list-desc">{{item.categoryLabel}} · 商城：{{item.mallVisibilityLabel}} · ¥{{item.priceYuan}} · 库存 {{item.stock}}</text>
  </view>

  <view class="section-header" style="margin-top:var(--spacing-md)">
    <text class="section-title">兼容套餐模板</text>
    <text class="section-subtitle">LEGACY PACKAGES</text>
  </view>
  <view class="list-card animate-fade-up" wx:for="{{overview.packages}}" wx:key="_id" style="animation-delay:{{0.2 + index*0.04}}s">
    <text class="list-title">{{item.name}}</text>
    <text class="list-desc">{{item.itemsText}}</text>
  </view>

  <view class="empty-block" wx:if="{{!overview.products.length && !overview.packages.length}}">
    <text class="empty-title">暂无商品数据</text>
  </view>

  <view class="safe-bottom"></view>
</view>
