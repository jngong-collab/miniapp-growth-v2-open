/* pages/workbench/verify/verify.wxss */

.page-workbench-verify {
  background: var(--bg-page);
  min-height: 100vh;
  padding: var(--spacing-lg);
}

.verify-header {
  text-align: center;
  padding: 40rpx 0 var(--spacing-xl);
}

.verify-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-title);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.verify-subtitle {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}

.code-input-section {
  margin-bottom: var(--spacing-lg);
}

.code-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-capsule);
  padding: var(--spacing-xs);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.code-input {
  flex: 1;
  height: 84rpx;
  padding: 0 var(--spacing-md);
  font-size: var(--font-lg);
  font-weight: 600;
  letter-spacing: 8rpx;
  color: var(--color-text-title);
}

.code-query-btn {
  flex-shrink: 0;
  padding: 0 var(--spacing-xl);
  height: 76rpx;
  line-height: 76rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-page);
  color: var(--color-text-muted);
  font-size: var(--font-sm);
  font-weight: 600;
  text-align: center;
  border: 1rpx solid var(--color-border);
}

.code-query-btn.active {
  background: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
}

.order-info-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.order-info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-md);
  border-bottom: 1rpx solid var(--color-border);
}

.order-info-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-title);
}

.order-type-tag {
  font-size: var(--font-xs);
  font-weight: 600;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-sm);
}

.tag-service { background: var(--color-eco-bg); color: var(--color-eco-dark); }
.tag-package { background: var(--color-primary-bg); color: var(--color-primary-dark); }

.service-select-section {
  margin-bottom: var(--spacing-md);
}

.service-select-label {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  display: block;
  margin-bottom: var(--spacing-sm);
  font-weight: 600;
}

.service-options {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.service-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-sm);
  background: var(--bg-page);
  border-radius: var(--radius-lg);
  border: 2rpx solid transparent;
}

.service-option.selected {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
}

.service-option-name {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-title);
}

.service-option-count {
  font-size: var(--font-sm);
  color: var(--color-primary-dark);
  font-weight: 600;
}

.verify-action-section {
  display: flex;
  gap: var(--spacing-sm);
}

.verify-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-base);
  font-weight: 700;
}

.verify-btn-confirm {
  background: var(--color-eco);
  color: #FFFFFF;
}

.verify-btn-cancel {
  background: var(--bg-page);
  color: var(--color-text-sub);
  border: 1rpx solid var(--color-border);
}

.verify-btn-reset {
  background: var(--color-primary);
  color: #FFFFFF;
  margin-top: var(--spacing-md);
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx var(--spacing-lg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.result-card.success { background: var(--color-eco-bg); }
.result-card.error { background: rgba(199,92,92,0.08); }

.result-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-md);
}

.result-msg {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-title);
}

.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
  font-size: var(--font-md);
  color: var(--color-text-sub);
  gap: var(--spacing-md);
}

.loader-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(0,0,0,0.05);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }
