<view class="page-workbench-staff">
  <view class="staff-header">
    <text class="staff-title">员工管理</text>
    <text class="staff-count">共 {{staffList.length}} 名员工</text>
  </view>

  <view class="add-btn card-press" bindtap="showAddStaff">
    <text class="add-btn-icon">+</text>
    <text class="add-btn-text">添加员工</text>
  </view>

  <view class="staff-list">
    <view class="staff-card animate-fade-up" wx:for="{{staffList}}" wx:key="openid" style="animation-delay:{{index*0.05}}s">
      <view class="staff-card-header">
        <view class="staff-avatar">👤</view>
        <view class="staff-info">
          <text class="staff-name">{{item.name}}</text>
          <text class="staff-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
        </view>
      </view>

      <view class="staff-perms">
        <view class="perm-tag" wx:for="{{item.permLabels}}" wx:key="*this" wx:for-item="label">
          {{label}}
        </view>
        <view class="perm-tag perm-empty" wx:if="{{!item.permLabels || item.permLabels.length === 0}}">
          无权限
        </view>
      </view>

      <view class="staff-actions">
        <view class="action-btn action-edit card-press" bindtap="editStaff" data-staff="{{item}}">编辑权限</view>
        <view class="action-btn action-remove card-press" bindtap="removeStaff" data-staff="{{item}}">移除</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && staffList.length === 0}}">
    <text class="empty-icon">👥</text>
    <text class="empty-text">还没有添加员工</text>
    <text class="empty-hint">添加员工后可为其分配核销与后台权限</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中…</text>
  </view>

  <!-- Add Modal -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeAddModal">
    <view class="modal-body" catchtap="">
      <view class="modal-title">添加员工</view>
      <view class="form-group">
        <text class="form-label">员工 OpenID *</text>
        <input class="form-input" placeholder="请输入员工的微信 openid" value="{{newStaffOpenid}}" bindinput="onNewOpenidInput" />
      </view>
      <view class="form-group">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="员工姓名" value="{{newStaffName}}" bindinput="onNewNameInput" />
      </view>
      <view class="form-group">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" placeholder="手机号（选填）" value="{{newStaffPhone}}" bindinput="onNewPhoneInput" />
      </view>
      <view class="form-group">
        <text class="form-label">权限设置</text>
        <view class="perm-checkbox-list">
          <view class="perm-checkbox-item card-press" wx:for="{{permOptions}}" wx:key="key" bindtap="toggleNewPerm" data-key="{{item.key}}">
            <view class="checkbox {{newStaffPerms.indexOf(item.key) !== -1 ? 'checked' : ''}}">
              <text wx:if="{{newStaffPerms.indexOf(item.key) !== -1}}">✓</text>
            </view>
            <view class="perm-checkbox-info">
              <text class="perm-checkbox-label">{{item.icon}} {{item.label}}</text>
              <text class="perm-checkbox-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-btn-cancel card-press" bindtap="closeAddModal">取消</view>
        <view class="modal-btn modal-btn-confirm card-press" bindtap="confirmAddStaff">确认添加</view>
      </view>
    </view>
  </view>

  <!-- Edit Modal -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditModal">
    <view class="modal-body" catchtap="">
      <view class="modal-title">编辑权限 - {{editingStaff.name}}</view>
      <view class="perm-checkbox-list">
        <view class="perm-checkbox-item card-press" wx:for="{{permOptions}}" wx:key="key"
              bindtap="toggleEditPerm" data-key="{{item.key}}">
          <view class="checkbox {{editingPerms.indexOf(item.key) !== -1 ? 'checked' : ''}}">
            <text wx:if="{{editingPerms.indexOf(item.key) !== -1}}">✓</text>
          </view>
          <view class="perm-checkbox-info">
            <text class="perm-checkbox-label">{{item.icon}} {{item.label}}</text>
            <text class="perm-checkbox-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-btn-cancel card-press" bindtap="closeEditModal">取消</view>
        <view class="modal-btn modal-btn-confirm card-press" bindtap="confirmEditPerms">保存权限</view>
      </view>
    </view>
  </view>
</view>
