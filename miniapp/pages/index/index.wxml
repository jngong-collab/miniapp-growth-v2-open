<!--pages/index/index.wxml-->
<view class="page-home">
  <!-- 温润背景装饰 -->
  <view class="bg-deco bg-deco-1"></view>
  <view class="bg-deco bg-deco-2"></view>

  <!-- Loading 骨架屏 -->
  <view class="skeleton-wrap" wx:if="{{loading}}">
    <view class="skeleton-header">
      <view class="skeleton-line skeleton-w60 skeleton-shimmer"></view>
      <view class="skeleton-line skeleton-w40 skeleton-shimmer" style="margin-top:16rpx"></view>
    </view>
    <view class="skeleton-bento">
      <view class="skeleton-block skeleton-large skeleton-shimmer"></view>
      <view class="skeleton-col">
        <view class="skeleton-block skeleton-small skeleton-shimmer"></view>
        <view class="skeleton-block skeleton-small skeleton-shimmer"></view>
      </view>
    </view>
    <view class="skeleton-block skeleton-banner skeleton-shimmer"></view>
    <view class="skeleton-products">
      <view class="skeleton-product skeleton-shimmer" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
    </view>
  </view>

  <!-- 主内容 -->
  <view class="home-content" wx:if="{{!loading}}">
    <!-- 品牌头部 -->
    <view class="header-section animate-fade-up">
      <view class="greeting-wrap">
        <text class="greeting-time">{{greeting}} {{greetingEmoji}}</text>
        <text class="store-name">{{storeInfo.name || '浴小主小儿推拿'}}</text>
      </view>
      <view class="location-pill card-press" bindtap="openLocation" wx:if="{{storeInfo.address}}">
        <text class="loc-icon">📍</text>
        <text class="loc-addr">{{storeInfo.address}}</text>
        <text class="loc-arrow">›</text>
      </view>
    </view>

    <!-- Bento 功能入口 -->
    <view class="bento-box animate-fade-up" style="animation-delay: 0.1s">
      <view class="bento-main card-press bg-grad-ai" bindtap="goToTongue">
        <view class="bento-main-content">
          <view class="bento-badge">AI 智能诊断</view>
          <text class="bento-main-title">拍舌识体质</text>
          <text class="bento-main-desc">黄帝内经 · 现代 AI 辅助</text>
        </view>
        <view class="bento-main-action">
          <text>立即体验</text>
          <text class="action-arrow">→</text>
        </view>
        <view class="bento-deco"></view>
      </view>
      <view class="bento-side">
        <view class="bento-sub card-press" bindtap="goToPackage">
          <view class="sub-icon-wrap" style="background:#F5EFE8">
            <text class="sub-icon">📋</text>
          </view>
          <view class="sub-text">
            <text class="sub-title">套餐查询</text>
            <text class="sub-desc">查看使用进度</text>
          </view>
        </view>
        <view class="bento-sub card-press" bindtap="goToLottery">
          <view class="sub-icon-wrap" style="background:#F0F5F1">
            <text class="sub-icon">🎁</text>
          </view>
          <view class="sub-text">
            <text class="sub-title">幸运抽奖</text>
            <text class="sub-desc">{{lotteryCampaign ? (lotteryCampaign.name || '每日好礼') : '每日好礼'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 裂变活动横幅 -->
    <view class="promo-section animate-fade-up" style="animation-delay: 0.18s" wx:if="{{fissionCampaigns.length > 0}}" bindtap="goToFission">
      <view class="promo-card card-press">
        <view class="promo-left">
          <view class="promo-badge">限时活动</view>
          <text class="promo-title">推荐好友购买【{{fissionCampaigns[0].productName}}】</text>
          <text class="promo-desc">每单返 ¥{{fissionCampaigns[0].cashbackAmountYuan}} · 已有 {{fissionCampaigns[0].soldCount || 0}} 人参与</text>
          <view class="promo-progress" wx:if="{{fissionCampaigns[0].soldPercent > 0}}">
            <view class="promo-progress-bar">
              <view class="promo-progress-fill" style="width: {{fissionCampaigns[0].soldPercent}}%"></view>
            </view>
          </view>
        </view>
        <view class="promo-right">
          <text class="promo-price">¥{{fissionCampaigns[0].activityPriceYuan}}</text>
          <view class="promo-btn">立即参与</view>
        </view>
      </view>
    </view>

    <!-- 推拿师推荐 -->
    <view class="therapist-section animate-fade-up" style="animation-delay: 0.22s" wx:if="{{therapist}}">
      <view class="section-header">
        <text class="section-title">儿童健康管理师</text>
        <text class="section-subtitle">Expert Therapist</text>
      </view>
      <view class="therapist-card card-float card-press">
        <view class="therapist-photo-wrap">
          <image class="therapist-photo" src="{{therapist.photo}}" mode="aspectFill" wx:if="{{therapist.photo}}"></image>
          <view class="therapist-photo-placeholder" wx:else>
            <text class="therapist-placeholder-emoji">👩‍⚕️</text>
          </view>
          <view class="therapist-cert-badge glass-panel" wx:if="{{therapist.certTitle}}">
            <text>{{therapist.certTitle}}</text>
          </view>
        </view>
        <view class="therapist-info">
          <view class="therapist-name-row">
            <text class="therapist-name">{{therapist.name}}</text>
            <text class="therapist-title">{{therapist.title}}</text>
          </view>
          <view class="therapist-stats">
            <view class="therapist-stat-item" wx:if="{{therapist.experience}}">
              <text class="stat-value">{{therapist.experience}}</text>
              <text class="stat-label">从业经验</text>
            </view>
            <view class="therapist-stat-item" wx:if="{{therapist.serviceCount}}">
              <text class="stat-value">{{therapist.serviceCount}}</text>
              <text class="stat-label">服务人次</text>
            </view>
            <view class="therapist-stat-item" wx:if="{{therapist.rating}}">
              <text class="stat-value">{{therapist.rating}}</text>
              <text class="stat-label">好评率</text>
            </view>
          </view>
          <text class="therapist-bio">{{therapist.bio}}</text>
          <view class="therapist-tags" wx:if="{{therapist.specialties && therapist.specialties.length > 0}}">
            <text class="therapist-tag" wx:for="{{therapist.specialties}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 套餐推荐 -->
    <view class="section-header animate-fade-up" style="animation-delay: 0.28s" wx:if="{{hotPackages.length > 0}}">
      <text class="section-title">调理套餐</text>
      <text class="section-subtitle">Recommended Packages</text>
    </view>
    <view class="package-card card-float card-press animate-fade-up" style="animation-delay: 0.32s" wx:for="{{hotPackages}}" wx:key="_id" wx:if="{{index < 1}}" bindtap="goToProduct" data-id="{{item._id}}">
      <view class="package-img-wrap">
        <image class="package-img" src="{{item.images[0]}}" mode="aspectFill" wx:if="{{item.images && item.images.length > 0 && item.images[0]}}"></image>
        <view class="package-img-placeholder" wx:else>
          <text class="placeholder-emoji">🎁</text>
        </view>
        <text class="tag tag-ai package-tag">套餐</text>
      </view>
      <view class="package-info">
        <text class="package-name">{{item.name}}</text>
        <text class="package-desc" wx:if="{{item.efficacy}}">{{item.efficacy}}</text>
        <view class="currency-box" style="margin-top:auto;padding-top:12rpx">
          <text class="currency-symbol">¥</text>
          <text class="currency-value">{{item.priceYuan}}</text>
          <text class="currency-original" wx:if="{{item.originalPriceYuan && item.originalPriceYuan !== '0.0'}}">¥{{item.originalPriceYuan}}</text>
        </view>
        <view class="package-action">查看详情 →</view>
      </view>
    </view>

    <!-- 产品优选 -->
    <view class="section-header animate-fade-up" style="animation-delay: 0.36s">
      <text class="section-title">甄选产品</text>
      <text class="section-subtitle">Premium Products</text>
    </view>

    <view class="products-grid animate-fade-up" style="animation-delay: 0.4s" wx:if="{{hotProducts.length > 0}}">
      <view class="grid-product-card card-float card-press" wx:for="{{hotProducts}}" wx:key="_id" wx:if="{{index < 4}}" bindtap="goToProduct" data-id="{{item._id}}">
        <view class="grid-product-img-wrap">
          <image class="grid-product-img" src="{{item.images[0]}}" mode="aspectFill" wx:if="{{item.images && item.images.length > 0 && item.images[0]}}"></image>
          <view class="product-img-placeholder" wx:else>
            <text class="placeholder-emoji">🧴</text>
          </view>
        </view>
        <view class="grid-product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="currency-box" style="margin-top:6rpx">
            <text class="currency-symbol">¥</text>
            <text class="currency-value">{{item.priceYuan}}</text>
            <text class="currency-original" wx:if="{{item.originalPriceYuan && item.originalPriceYuan !== '0.0'}}">¥{{item.originalPriceYuan}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state animate-fade-up" style="animation-delay: 0.4s" wx:if="{{hotProducts.length === 0 && hotPackages.length === 0}}">
      <text class="empty-icon">🍃</text>
      <text class="empty-text">商品即将上架，敬请期待</text>
    </view>

    <view class="safe-bottom"></view>
  </view>
</view>
