/* pages/product-detail/product-detail.wxss — V2 沉浸式设计 */

/* ====== 页面基础 ====== */
.page-detail {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-page, #FAF6F1);
  padding-bottom: 200rpx;
}

/* 背景装饰 */
.bg-deco {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.45;
  z-index: 0;
}
.deco-1 {
  width: 500rpx; height: 500rpx;
  background: var(--color-primary-bg, rgba(192,139,92,0.12));
  top: -150rpx; right: -100rpx;
}
.deco-2 {
  width: 400rpx; height: 400rpx;
  background: var(--color-ai-bg, rgba(108,92,231,0.1));
  top: 600rpx; left: -150rpx;
}

/* ====== 加载状态 ====== */
.loader-wrap {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 60vh; gap: var(--spacing-md);
  position: relative; z-index: 1;
}
.loader-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid rgba(0,0,0,0.06);
  border-top-color: var(--color-primary, #C08B5C);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loader-text { font-size: var(--font-base); color: var(--color-text-sub, #999); }

/* ====== 入场动画 ====== */
.animate-fade-up { animation: fadeUp 0.45s ease both; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(var(--spacing-md)); }
  to { opacity: 1; transform: translateY(0); }
}

/* ====== 通用卡片 ====== */
.card-float {
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

/* ====== 1. Hero 图片轮播 ====== */
.hero-gallery {
  position: relative;
  z-index: 1;
}
.gallery-swiper {
  height: 680rpx;
}
.gallery-img {
  width: 100%; height: 100%;
  display: block;
}
.gallery-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(145deg, #f0ebe4, #e8e0d8);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: var(--spacing-sm);
}
.gallery-placeholder-emoji { font-size: 100rpx; }
.gallery-placeholder-text {
  font-size: var(--font-base); color: var(--color-text-sub, #999);
}

/* ====== 内容区域 ====== */
.content-wrap {
  position: relative; z-index: 1;
  padding: var(--spacing-md) var(--spacing-lg);
  margin-top: -40rpx;
  display: flex; flex-direction: column; gap: var(--spacing-sm);
}

/* ====== 2. 价格卡片 ====== */
.price-card {
  padding: var(--spacing-md) var(--spacing-lg);
}
.price-main-row {
  display: flex; align-items: baseline;
  flex-wrap: wrap; gap: var(--spacing-xs);
}
.price-group {
  display: flex; align-items: baseline;
}
.price-sym {
  font-size: var(--font-base); color: var(--color-primary, #C08B5C);
  font-weight: 700;
}
.price-num {
  font-size: 56rpx; color: var(--color-primary, #C08B5C);
  font-weight: 800; letter-spacing: -2rpx;
  line-height: 1;
}
.price-extra {
  display: flex; align-items: center; gap: var(--spacing-xs);
}
.price-orig {
  font-size: var(--font-sm); color: var(--color-text-muted, #bbb);
  text-decoration: line-through;
}
.discount-tag {
  background: linear-gradient(135deg, #C08B5C, #A67443);
  color: #fff;
  font-size: var(--font-xs); font-weight: 700;
  padding: 4rpx var(--spacing-sm);
  border-radius: var(--radius-capsule);
}
.sold-text {
  font-size: var(--font-sm); color: var(--color-text-muted, #bbb);
  margin-left: auto;
}

/* ====== 3. 产品信息卡片 ====== */
.info-card {
  padding: var(--spacing-md) var(--spacing-lg);
}
.info-header {
  display: flex; align-items: flex-start; gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}
.type-badge {
  display: inline-flex;
  font-size: var(--font-xs); font-weight: 700;
  padding: 6rpx var(--spacing-sm);
  border-radius: var(--radius-capsule);
  flex-shrink: 0;
  margin-top: var(--spacing-xs);
}
.type-physical { background: #E6F4FF; color: #1677FF; }
.type-service { background: #F6FFED; color: #52C41A; }
.type-package { background: #FFF7E6; color: #FA8C16; }

.product-name {
  font-size: var(--font-lg); font-weight: 800;
  color: var(--color-text-title, #1a1a2e);
  line-height: 1.4;
  flex: 1;
}
.product-desc {
  font-size: var(--font-base); color: var(--color-text-sub, #888);
  line-height: 1.7; display: block;
  margin-bottom: var(--spacing-sm);
}

/* 功效条 */
.efficacy-strip {
  display: flex; align-items: flex-start; gap: var(--spacing-xs);
  background: linear-gradient(135deg, rgba(192,139,92,0.06), rgba(192,139,92,0.02));
  border: 1rpx solid rgba(192,139,92,0.1);
  border-radius: var(--radius-sm);
  padding: var(--spacing-md);
}
.efficacy-icon { font-size: var(--font-sm); flex-shrink: 0; margin-top: 2rpx; }
.efficacy-text {
  font-size: var(--font-base); color: var(--color-primary, #C08B5C);
  line-height: 1.6; font-weight: 500;
}

/* ====== 4. 裂变活动卡片 ====== */
.fission-card {
  padding: var(--spacing-md) var(--spacing-lg);
  background: linear-gradient(135deg, #FFF8F0, #FFF2E6) !important;
  border: 1rpx solid rgba(250,140,22,0.2);
  display: flex; align-items: center;
  position: relative;
}
.fission-left { flex: 1; }
.fission-title-row {
  display: flex; align-items: center; gap: var(--spacing-xs);
  margin-bottom: var(--spacing-xs);
}
.fission-fire { font-size: var(--font-base); }
.fission-title {
  font-size: var(--font-base); font-weight: 800;
  color: #D46B08;
}
.fission-desc {
  font-size: var(--font-sm); color: #AD6800;
  display: block;
}
.fission-right {
  display: flex; flex-direction: column;
  align-items: center; margin: 0 var(--spacing-xs);
}
.fission-amount {
  font-size: var(--font-lg); font-weight: 800;
  color: var(--color-primary, #C08B5C);
}
.fission-label {
  font-size: var(--font-xs); color: var(--color-text-sub, #999);
}
.fission-arrow {
  font-size: var(--font-lg); color: #D46B08;
  font-weight: 300;
}

/* ====== 5. 套餐明细卡片 ====== */
.package-card {
  padding: var(--spacing-md) var(--spacing-lg);
}
.package-header {
  display: flex; align-items: center; gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}
.package-icon { font-size: var(--font-base); }
.package-title {
  font-size: var(--font-base); font-weight: 800;
  color: var(--color-text-title, #1a1a2e);
}
.package-list {
  display: flex; flex-wrap: wrap; gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}
.package-chip {
  display: inline-flex; align-items: center; gap: var(--spacing-xs);
  background: rgba(0,0,0,0.03);
  border-radius: var(--radius-capsule);
  padding: var(--spacing-xs) var(--spacing-md);
}
.package-chip-name {
  font-size: var(--font-sm); color: var(--color-text-title, #1a1a2e);
  font-weight: 600;
}
.package-chip-count {
  font-size: var(--font-sm); color: var(--color-primary, #C08B5C);
  font-weight: 700;
}
.package-valid {
  font-size: var(--font-sm); color: var(--color-text-muted, #bbb);
  display: block;
}

/* ====== 6. 服务保障卡片 ====== */
.service-card {
  padding: var(--spacing-md) var(--spacing-lg);
}
.service-row {
  display: flex; justify-content: space-around;
}
.service-item {
  display: flex; flex-direction: column;
  align-items: center; gap: var(--spacing-xs);
}
.service-icon { font-size: var(--font-lg); }
.service-label {
  font-size: var(--font-sm); color: var(--color-text-sub, #888);
  font-weight: 500;
}

/* ====== 底部操作栏 ====== */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0,0,0,0.04);
  z-index: 100;
}
.bar-actions {
  display: flex; gap: var(--spacing-xs);
}
.bar-action-item {
  display: flex; flex-direction: column;
  align-items: center; padding: 0 var(--spacing-md);
}
.bar-action-icon { font-size: var(--font-lg); }
.bar-action-text {
  font-size: 18rpx; color: var(--color-text-sub, #888);
  margin-top: 2rpx;
}
.bar-buy-btn {
  flex: 1; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, var(--color-primary, #C08B5C), #C75C5C);
  color: #fff; font-size: var(--font-base); font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(192,139,92,0.3);
  transition: transform 0.2s ease;
}
.bar-buy-btn:active {
  transform: scale(0.97);
}

/* ====== 购买弹窗 ====== */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
  display: flex; align-items: flex-end;
}
.modal-sheet {
  background: #fff;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--spacing-sm) var(--spacing-lg) calc(env(safe-area-inset-bottom) + var(--spacing-lg));
  width: 100%;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-handle {
  width: 64rpx; height: 8rpx;
  background: rgba(0,0,0,0.1);
  border-radius: 4rpx;
  margin: 0 auto var(--spacing-lg);
}

.modal-product-row {
  display: flex; align-items: center;
  margin-bottom: var(--spacing-lg); gap: var(--spacing-md);
}
.modal-img-wrap {
  width: 160rpx; height: 160rpx;
  border-radius: var(--radius-md); overflow: hidden;
  flex-shrink: 0; background: #f0f0f0;
}
.modal-img {
  width: 100%; height: 100%;
}
.modal-product-info {
  flex: 1; display: flex; flex-direction: column; gap: var(--spacing-xs);
}
.modal-product-name {
  font-size: var(--font-base); font-weight: 700;
  color: var(--color-text-title, #1a1a2e);
  display: block;
}
.modal-price-row {
  display: flex; align-items: baseline;
}
.modal-price-sym {
  font-size: var(--font-sm); color: var(--color-primary, #C08B5C);
  font-weight: 700;
}
.modal-price-num {
  font-size: var(--font-xl); color: var(--color-primary, #C08B5C);
  font-weight: 800; line-height: 1;
}
.modal-stock {
  font-size: var(--font-sm); color: var(--color-text-muted, #bbb);
  display: block;
}

/* 数量控制 */
.modal-qty-row {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  margin-bottom: var(--spacing-md);
}
.modal-qty-label {
  font-size: var(--font-base); color: var(--color-text-title, #1a1a2e);
  font-weight: 600;
}
.modal-qty-ctrl {
  display: flex; align-items: center; gap: var(--spacing-md);
}
.qty-btn {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.04);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-lg); color: var(--color-text-title, #1a1a2e);
  transition: background 0.2s;
}
.qty-btn:active { background: rgba(0,0,0,0.08); }
.qty-btn.disabled { color: var(--color-text-muted, #ccc); }
.qty-num {
  font-size: var(--font-md); font-weight: 700;
  color: var(--color-text-title, #1a1a2e);
  min-width: 48rpx; text-align: center;
}

.modal-total-row {
  display: flex; align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
  font-size: var(--font-base); color: var(--color-text-title, #1a1a2e);
  font-weight: 600;
}
.modal-total-price {
  display: flex; align-items: baseline;
}

.modal-confirm-btn {
  width: 100%; height: 92rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, var(--color-primary, #C08B5C), #C75C5C);
  color: #fff; font-size: var(--font-md); font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(192,139,92,0.25);
  transition: transform 0.2s ease;
}
.modal-confirm-btn:active {
  transform: scale(0.97);
}
