/* pages/product-detail/product-detail.wxss — 现代东方成交页 */

.page-detail {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-page);
  padding-bottom: 200rpx;
}

.bg-deco {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
  z-index: 0;
  pointer-events: none;
}

.deco-1 {
  width: 520rpx; height: 520rpx;
  background: var(--color-primary-bg);
  top: -160rpx; right: -120rpx;
}

.deco-2 {
  width: 400rpx; height: 400rpx;
  background: var(--color-ai-bg);
  top: 560rpx; left: -160rpx;
}

/* 加载状态 */
.loader-wrap {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 60vh; gap: var(--spacing-md);
  position: relative; z-index: 1;
}

.loader-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid rgba(0,0,0,0.05);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }
.loader-text { font-size: var(--font-base); color: var(--color-text-sub); }

.animate-fade-up { animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards; opacity: 0; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Hero 图片轮播 */
.hero-gallery {
  position: relative;
  z-index: 1;
}

.gallery-swiper {
  height: 640rpx;
}

.gallery-img {
  width: 100%; height: 100%;
  display: block;
}

.gallery-placeholder {
  width: 100%; height: 100%;
  background: var(--color-primary-bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: var(--spacing-sm);
}

.gallery-placeholder-emoji { font-size: 96rpx; }
.gallery-placeholder-text {
  font-size: var(--font-base); color: var(--color-text-sub);
}

/* 内容区域 */
.content-wrap {
  position: relative; z-index: 1;
  padding: var(--spacing-md) var(--spacing-lg);
  margin-top: -40rpx;
  display: flex; flex-direction: column; gap: var(--spacing-sm);
}

/* 价格卡片 */
.price-card {
  padding: var(--spacing-md) var(--spacing-lg);
}

.price-main-row {
  display: flex; align-items: baseline;
  flex-wrap: wrap; gap: var(--spacing-xs);
}

.price-group {
  display: flex; align-items: baseline;
}

.price-sym {
  font-size: var(--font-sm); color: var(--color-primary-dark);
  font-weight: 700;
}

.price-num {
  font-size: 56rpx; color: var(--color-primary-dark);
  font-weight: 800; letter-spacing: -2rpx;
  line-height: 1;
}

.price-extra {
  display: flex; align-items: center; gap: var(--spacing-xs);
}

.price-orig {
  font-size: var(--font-sm); color: var(--color-text-muted);
  text-decoration: line-through;
}

.discount-tag {
  background: var(--color-primary-bg);
  color: var(--color-primary-dark);
  font-size: var(--font-xs); font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-capsule);
}

.sold-text {
  font-size: var(--font-sm); color: var(--color-text-muted);
  margin-left: auto;
}

/* 产品信息卡片 */
.info-card {
  padding: var(--spacing-md) var(--spacing-lg);
}

.info-header {
  display: flex; align-items: flex-start; gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}

.type-badge {
  display: inline-flex;
  font-size: var(--font-xs); font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-capsule);
  flex-shrink: 0;
  margin-top: 6rpx;
}

.type-physical { background: var(--color-ai-bg); color: var(--color-ai); }
.type-service { background: var(--color-eco-bg); color: var(--color-eco-dark); }
.type-package { background: var(--color-primary-bg); color: var(--color-primary-dark); }

.product-name {
  font-size: var(--font-lg); font-weight: 700;
  color: var(--color-text-title);
  line-height: 1.4;
  flex: 1;
}

.product-desc {
  font-size: var(--font-sm); color: var(--color-text-sub);
  line-height: 1.7; display: block;
  margin-bottom: var(--spacing-sm);
}

/* 功效条 */
.efficacy-strip {
  display: flex; align-items: flex-start; gap: var(--spacing-xs);
  background: var(--color-primary-bg);
  border-radius: var(--radius-sm);
  padding: var(--spacing-md);
}

.efficacy-icon { font-size: var(--font-sm); flex-shrink: 0; margin-top: 2rpx; }
.efficacy-text {
  font-size: var(--font-sm); color: var(--color-primary-dark);
  line-height: 1.6; font-weight: 500;
}

/* 裂变活动卡片 */
.fission-card {
  padding: var(--spacing-md) var(--spacing-lg);
  background: linear-gradient(135deg, #FFF9F5, #FFFFFF) !important;
  border: 1rpx solid rgba(184,145,107,0.15);
  display: flex; align-items: center;
  position: relative;
}

.fission-left { flex: 1; }
.fission-title-row {
  display: flex; align-items: center; gap: var(--spacing-xs);
  margin-bottom: var(--spacing-xs);
}

.fission-icon { font-size: var(--font-sm); }
.fission-title {
  font-size: var(--font-sm); font-weight: 700;
  color: var(--color-text-title);
}

.fission-desc {
  font-size: var(--font-xs); color: var(--color-text-sub);
  display: block;
}

.fission-right {
  display: flex; flex-direction: column;
  align-items: center; margin: 0 var(--spacing-xs);
}

.fission-amount {
  font-size: var(--font-lg); font-weight: 800;
  color: var(--color-gold);
}

.fission-label {
  font-size: var(--font-xs); color: var(--color-text-sub);
}

.fission-arrow {
  font-size: var(--font-md); color: var(--color-text-muted);
  font-weight: 300;
}

/* 套餐明细卡片 */
.package-card {
  padding: var(--spacing-md) var(--spacing-lg);
}

.package-header {
  display: flex; align-items: center; gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}

.package-icon { font-size: var(--font-base); }
.package-title {
  font-size: var(--font-base); font-weight: 700;
  color: var(--color-text-title);
}

.package-list {
  display: flex; flex-wrap: wrap; gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}

.package-chip {
  display: inline-flex; align-items: center; gap: var(--spacing-xs);
  background: var(--bg-page);
  border-radius: var(--radius-capsule);
  padding: var(--spacing-xs) var(--spacing-md);
  border: 1rpx solid var(--color-border);
}

.package-chip-name {
  font-size: var(--font-sm); color: var(--color-text-title);
  font-weight: 500;
}

.package-chip-count {
  font-size: var(--font-sm); color: var(--color-primary-dark);
  font-weight: 700;
}

.package-valid {
  font-size: var(--font-xs); color: var(--color-text-muted);
  display: block;
}

/* 服务保障卡片 */
.service-card {
  padding: var(--spacing-md) var(--spacing-lg);
}

.service-row {
  display: flex; justify-content: space-around;
}

.service-item {
  display: flex; flex-direction: column;
  align-items: center; gap: var(--spacing-xs);
}

.service-icon { font-size: var(--font-lg); }
.service-label {
  font-size: var(--font-xs); color: var(--color-text-sub);
  font-weight: 500;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 112rpx;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(20rpx); -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
}

.bar-icon-wrap {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  width: 72rpx; height: 72rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  flex-shrink: 0;
  position: relative;
  box-sizing: border-box;
}

/* 分享按钮：透明覆盖层，不占用布局 */
.share-btn {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  z-index: 2;
}
.share-btn::after {
  border: none;
}

.bar-icon-img {
  width: 36rpx;
  height: 36rpx;
}
.bar-icon-label {
  font-size: 16rpx;
  color: var(--color-text-sub);
  margin-top: 2rpx;
  line-height: 1;
}

.bar-cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 24rpx;
  height: 24rpx;
  padding: 0 4rpx;
  border-radius: 12rpx;
  background: #D65C4F;
  color: #fff;
  font-size: 16rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700;
  z-index: 1;
}

.btn-cart,
.btn-buy {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  box-sizing: border-box;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.btn-cart {
  flex: 1;
  max-width: 240rpx;
  min-width: 160rpx;
  color: var(--color-primary-dark);
  background: #F5EFE9;
  border: 1rpx solid rgba(184,145,107,0.25);
}

.btn-buy {
  flex: 1.5;
  max-width: 340rpx;
  min-width: 200rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(184,145,107,0.25);
}

.btn-buy--full {
  flex: 1;
  max-width: 100%;
}

.btn-cart:active,
.btn-buy:active {
  transform: scale(0.97);
  opacity: 0.92;
}

/* 购买弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
  display: flex; align-items: flex-end;
}

.modal-sheet {
  background: var(--bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--spacing-sm) var(--spacing-lg) calc(env(safe-area-inset-bottom) + var(--spacing-lg));
  width: 100%;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-handle {
  width: 64rpx; height: 8rpx;
  background: var(--color-border);
  border-radius: 4rpx;
  margin: 0 auto var(--spacing-lg);
}

.modal-product-row {
  display: flex; align-items: center;
  margin-bottom: var(--spacing-lg); gap: var(--spacing-md);
}

.modal-img-wrap {
  width: 160rpx; height: 160rpx;
  border-radius: var(--radius-md); overflow: hidden;
  flex-shrink: 0; background: var(--bg-page);
}

.modal-img { width: 100%; height: 100%; }

.modal-product-info {
  flex: 1; display: flex; flex-direction: column; gap: var(--spacing-xs);
}

.modal-product-name {
  font-size: var(--font-base); font-weight: 700;
  color: var(--color-text-title);
  display: block;
}

.modal-price-row {
  display: flex; align-items: baseline;
}

.modal-price-sym {
  font-size: var(--font-sm); color: var(--color-primary-dark);
  font-weight: 700;
}

.modal-price-num {
  font-size: var(--font-xl); color: var(--color-primary-dark);
  font-weight: 800; line-height: 1;
}

.modal-stock {
  font-size: var(--font-sm); color: var(--color-text-muted);
  display: block;
}

/* 数量控制 */
.modal-qty-row {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-top: 1rpx solid var(--color-border);
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-md);
}

.modal-qty-label {
  font-size: var(--font-base); color: var(--color-text-title);
  font-weight: 600;
}

.modal-qty-ctrl {
  display: flex; align-items: center; gap: var(--spacing-md);
}

.qty-btn {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: var(--bg-page);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-lg); color: var(--color-text-title);
  border: 1rpx solid var(--color-border);
}

.qty-btn.disabled { color: var(--color-text-muted); background: transparent; }

.qty-num {
  font-size: var(--font-md); font-weight: 700;
  color: var(--color-text-title);
  min-width: 48rpx; text-align: center;
}

.modal-total-row {
  display: flex; align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
  font-size: var(--font-base); color: var(--color-text-title);
  font-weight: 600;
}

.modal-total-price {
  display: flex; align-items: baseline;
}

.modal-confirm-btn {
  width: 100%; height: 92rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff; font-size: var(--font-md); font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(184,145,107,0.18);
  transition: transform 0.2s ease;
}

.modal-confirm-btn:active { transform: scale(0.97); }
