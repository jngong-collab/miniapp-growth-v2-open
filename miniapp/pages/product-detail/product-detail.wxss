/* pages/product-detail/product-detail.wxss — 现代东方成交页 */

.page-detail {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-page);
  padding-bottom: 200rpx;
}

.bg-deco {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
  z-index: 0;
  pointer-events: none;
}

.deco-1 {
  width: 520rpx; height: 520rpx;
  background: var(--color-primary-bg);
  top: -160rpx; right: -120rpx;
}

.deco-2 {
  width: 400rpx; height: 400rpx;
  background: var(--color-ai-bg);
  top: 560rpx; left: -160rpx;
}

/* 加载状态 */
.loader-wrap {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 60vh; gap: var(--spacing-md);
  position: relative; z-index: 1;
}

.loader-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid rgba(0,0,0,0.05);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }
.loader-text { font-size: var(--font-base); color: var(--color-text-sub); }

.animate-fade-up { animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards; opacity: 0; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Hero 图片轮播 */
.hero-gallery {
  position: relative;
  z-index: 1;
}

.gallery-swiper {
  height: 640rpx;
}

.gallery-img {
  width: 100%; height: 100%;
  display: block;
}

.gallery-placeholder {
  width: 100%; height: 100%;
  background: var(--color-primary-bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: var(--spacing-sm);
}

.gallery-placeholder-emoji { font-size: 96rpx; }
.gallery-placeholder-text {
  font-size: var(--font-base); color: var(--color-text-sub);
}

/* 内容区域 */
.content-wrap {
  position: relative; z-index: 1;
  padding: var(--spacing-md) var(--spacing-lg);
  margin-top: -40rpx;
  display: flex; flex-direction: column; gap: var(--spacing-sm);
}

/* 价格卡片 */
.price-card {
  padding: 40rpx 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  margin-top: -60rpx;
  z-index: 10;
}

.price-main-row {
  display: flex; align-items: baseline;
  flex-wrap: wrap; gap: var(--spacing-sm);
}

.price-group {
  display: flex; align-items: baseline;
}

.price-sym {
  font-size: 32rpx; color: var(--color-primary-dark);
  font-weight: 800;
  margin-right: 4rpx;
}

.price-num {
  font-size: 64rpx; color: var(--color-primary-dark);
  font-weight: 800; letter-spacing: -2rpx;
  line-height: 1;
}

.price-extra {
  display: flex; align-items: center; gap: 16rpx;
  background: rgba(184,145,107,0.06);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.price-orig {
  font-size: 26rpx; color: var(--color-text-muted);
  text-decoration: line-through;
}

.discount-tag {
  color: #E63F32;
  font-size: 22rpx; font-weight: 800;
}

.sold-text {
  font-size: 24rpx; color: var(--color-text-muted);
  margin-left: auto;
  font-weight: 500;
}

/* 产品信息卡片 */
.info-card {
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
}

.info-header {
  display: flex; align-items: flex-start; gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-badge {
  display: inline-flex;
  font-size: 20rpx; font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.type-physical { background: var(--color-ai-bg); color: var(--color-ai); }
.type-service { background: var(--color-eco-bg); color: var(--color-eco-dark); }
.type-package { background: linear-gradient(135deg, #1f1f1f, #333333); color: #fff; }

.product-name {
  font-size: 36rpx; font-weight: 800;
  color: var(--color-text-title);
  line-height: 1.4;
  flex: 1;
}

.product-desc {
  font-size: 28rpx; color: var(--color-text-sub);
  line-height: 1.6; display: block;
  margin-bottom: 24rpx;
  background: #fdfbf9;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid var(--color-primary);
}

/* 功效条 */
.efficacy-strip {
  display: flex; align-items: flex-start; gap: 12rpx;
  background: rgba(184,145,107,0.08);
  border-radius: 12rpx;
  padding: 24rpx;
}

.efficacy-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.efficacy-text {
  font-size: 26rpx; color: var(--color-primary-dark);
  line-height: 1.6; font-weight: 600;
}

/* 裂变活动卡片 */
.fission-card {
  padding: 32rpx;
  background: linear-gradient(135deg, #FFF6E5, #FFFFFF) !important;
  border: 1rpx solid rgba(255,166,77,0.3);
  display: flex; align-items: center;
  position: relative;
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,166,77,0.1);
}

.fission-left { flex: 1; }
.fission-title-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 12rpx;
}

.fission-icon { font-size: 32rpx; }
.fission-title {
  font-size: 30rpx; font-weight: 800;
  color: #D65C4F;
}

.fission-desc {
  font-size: 24rpx; color: var(--color-text-sub);
  display: block;
}

.fission-right {
  display: flex; flex-direction: column;
  align-items: center; margin: 0 16rpx;
  background: #fff;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx dashed rgba(255,166,77,0.4);
}

.fission-amount {
  font-size: 36rpx; font-weight: 800;
  color: #D65C4F;
  line-height: 1.2;
}

.fission-label {
  font-size: 20rpx; color: var(--color-text-sub);
  font-weight: 600;
}

.fission-arrow {
  font-size: 40rpx; color: var(--color-text-muted);
  font-weight: 300;
}

/* 套餐明细卡片 */
.package-card {
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(184,145,107,0.15);
  margin-top: 16rpx;
}

.package-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx dashed var(--color-border);
}

.package-header-left {
  display: flex; align-items: center; gap: 12rpx;
}

.package-icon { font-size: 32rpx; }
.package-title {
  font-size: 32rpx; font-weight: 800;
  color: var(--color-text-title);
  letter-spacing: 0.5rpx;
}

.package-valid-tag {
  font-size: 22rpx;
  color: var(--color-primary-dark);
  background: var(--color-primary-bg);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.package-list {
  display: flex; flex-direction: column; gap: 20rpx;
  margin-bottom: 8rpx;
}

.package-row {
  display: flex; align-items: center; justify-content: space-between;
  position: relative;
  padding: 4rpx 0;
}

.package-row::after {
  content: "";
  position: absolute;
  bottom: 12rpx;
  left: 0;
  right: 0;
  border-bottom: 1rpx dotted #E5E5E5;
  z-index: 0;
}

.package-row-name {
  font-size: 28rpx; color: var(--color-text-title);
  font-weight: 600;
  background: var(--bg-card);
  padding-right: 16rpx;
  position: relative;
  z-index: 1;
}

.package-row-count {
  font-size: 28rpx; color: var(--color-primary-dark);
  font-weight: 700;
  background: var(--bg-card);
  padding-left: 16rpx;
  position: relative;
  z-index: 1;
}

/* 服务保障卡片 */
.service-card {
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
}

.service-row {
  display: flex; justify-content: space-around;
  padding: 16rpx 0;
}

.service-item {
  display: flex; flex-direction: column;
  align-items: center; gap: 12rpx;
}

.service-icon { font-size: 40rpx; }
.service-label {
  font-size: 24rpx; color: var(--color-text-title);
  font-weight: 600;
}

/* 图文详情 */
.detail-card {
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
}

.detail-header {
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 32rpx; font-weight: 800;
  color: var(--color-text-title);
  letter-spacing: 0.5rpx;
}

.detail-content {
  display: flex; flex-direction: column; gap: 24rpx;
}

.detail-text {
  font-size: 28rpx; color: var(--color-text-sub);
  line-height: 1.8;
  white-space: pre-wrap;
}

.detail-img {
  width: 100%;
  border-radius: 12rpx;
  background: #f5f5f5;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 120rpx;
  padding: 0 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255,255,255,0.98);
  backdrop-filter: blur(20rpx); -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0,0,0,0.05);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.03);
}

.bar-icon-wrap {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  width: 80rpx; height: 80rpx;
  border-radius: 20rpx;
  background: transparent;
  flex-shrink: 0;
  position: relative;
  box-sizing: border-box;
  transition: background 0.2s;
}

.bar-icon-wrap:active {
  background: rgba(0,0,0,0.03);
}

/* 分享按钮：透明覆盖层，不占用布局 */
.share-btn {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  z-index: 2;
}
.share-btn::after {
  border: none;
}

.bar-icon-img {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}
.bar-icon-label {
  font-size: 18rpx;
  color: var(--color-text-sub);
  margin-top: 0;
  line-height: 1;
  font-weight: 500;
}

.bar-cart-badge {
  position: absolute;
  top: 4rpx;
  right: 6rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  border-radius: 14rpx;
  background: #E63F32;
  color: #fff;
  font-size: 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700;
  z-index: 1;
  border: 2rpx solid #fff;
}

.action-btns-wrap {
  flex: 1;
  display: flex;
  gap: 16rpx;
  height: 88rpx;
}

.btn-cart,
.btn-buy {
  height: 100%;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  box-sizing: border-box;
  transition: transform 0.15s ease, opacity 0.15s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cart {
  flex: 1;
  color: var(--color-primary-dark);
  background: #FFF7F0;
  border: 2rpx solid var(--color-primary);
}

.btn-buy {
  flex: 1.2;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(184,145,107,0.3);
}

.btn-buy--full {
  flex: 1;
  max-width: 100%;
  font-size: 32rpx;
  letter-spacing: 1rpx;
}

.btn-cart:active,
.btn-buy:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 购买弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
  display: flex; align-items: flex-end;
}

.modal-sheet {
  background: var(--bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--spacing-sm) var(--spacing-lg) calc(env(safe-area-inset-bottom) + var(--spacing-lg));
  width: 100%;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-handle {
  width: 64rpx; height: 8rpx;
  background: var(--color-border);
  border-radius: 4rpx;
  margin: 0 auto var(--spacing-lg);
}

.modal-product-row {
  display: flex; align-items: center;
  margin-bottom: var(--spacing-lg); gap: var(--spacing-md);
}

.modal-img-wrap {
  width: 160rpx; height: 160rpx;
  border-radius: var(--radius-md); overflow: hidden;
  flex-shrink: 0; background: var(--bg-page);
}

.modal-img { width: 100%; height: 100%; }

.modal-product-info {
  flex: 1; display: flex; flex-direction: column; gap: var(--spacing-xs);
}

.modal-product-name {
  font-size: var(--font-base); font-weight: 700;
  color: var(--color-text-title);
  display: block;
}

.modal-price-row {
  display: flex; align-items: baseline;
}

.modal-price-sym {
  font-size: var(--font-sm); color: var(--color-primary-dark);
  font-weight: 700;
}

.modal-price-num {
  font-size: var(--font-xl); color: var(--color-primary-dark);
  font-weight: 800; line-height: 1;
}

.modal-stock {
  font-size: var(--font-sm); color: var(--color-text-muted);
  display: block;
}

/* 数量控制 */
.modal-qty-row {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-top: 1rpx solid var(--color-border);
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-md);
}

.modal-qty-label {
  font-size: var(--font-base); color: var(--color-text-title);
  font-weight: 600;
}

.modal-qty-ctrl {
  display: flex; align-items: center; gap: var(--spacing-md);
}

.qty-btn {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: var(--bg-page);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-lg); color: var(--color-text-title);
  border: 1rpx solid var(--color-border);
}

.qty-btn.disabled { color: var(--color-text-muted); background: transparent; }

.qty-num {
  font-size: var(--font-md); font-weight: 700;
  color: var(--color-text-title);
  min-width: 48rpx; text-align: center;
}

.modal-total-row {
  display: flex; align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
  font-size: var(--font-base); color: var(--color-text-title);
  font-weight: 600;
}

.modal-total-price {
  display: flex; align-items: baseline;
}

.modal-confirm-btn {
  width: 100%; height: 92rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff; font-size: var(--font-md); font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(184,145,107,0.18);
  transition: transform 0.2s ease;
}

.modal-confirm-btn:active { transform: scale(0.97); }
