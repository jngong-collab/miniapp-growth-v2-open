/* pages/tongue-report/tongue-report.wxss — V3 统一首页风格 */

/* ====== 页面基础 ====== */
.page-report {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-page);
  padding-bottom: 200rpx;
}

/* 背景装饰（与首页identical） */
.bg-deco {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.5;
  z-index: 0;
}
.deco-1 {
  width: 500rpx; height: 500rpx;
  background: var(--color-primary-bg);
  top: -150rpx; right: -100rpx;
}
.deco-2 {
  width: 400rpx; height: 400rpx;
  background: var(--color-ai-bg);
  top: 400rpx; left: -150rpx;
}

.report-content {
  position: relative;
  z-index: 1;
  padding: var(--spacing-md) var(--spacing-lg);
}

/* ====== 加载状态 ====== */
.loader-wrap {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 60vh; gap: var(--spacing-md);
}
.loader-spinner {
  width: 56rpx; height: 56rpx; border: 4rpx solid rgba(0,0,0,0.06);
  border-top-color: var(--color-primary); border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loader-text { font-size: var(--font-sm); color: var(--color-text-sub); }

/* ====== 入场动画 ====== */
.animate-fade-up { animation: fadeUp 0.45s ease both; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(var(--spacing-md)); }
  to { opacity: 1; transform: translateY(0); }
}

/* ====== 通用区块样式（复用首页） ====== */
.section {
  margin-bottom: var(--spacing-md);
}
.section-header {
  display: flex; flex-direction: column; margin-bottom: var(--spacing-sm);
}
.section-title {
  font-size: var(--font-lg); font-weight: 800; color: var(--color-text-title);
  letter-spacing: -0.5rpx;
}
.section-subtitle {
  font-size: var(--font-xs); color: var(--color-text-muted); font-weight: 600;
  text-transform: uppercase; letter-spacing: 2rpx; margin-top: 2rpx;
}

/* ====== 1. 顶部 Hero ====== */
.hero-section {
  margin-bottom: var(--spacing-md);
}
.hero-greeting {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: var(--spacing-md);
}
.hero-title {
  font-size: var(--font-xl); font-weight: 800; color: var(--color-text-title);
}
.hero-date {
  font-size: var(--font-sm); color: var(--color-text-sub);
}

.hero-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.hero-top {
  display: flex; padding: var(--spacing-md); gap: var(--spacing-md); align-items: center;
}
.hero-photo-wrap {
  width: 160rpx; height: 160rpx; border-radius: var(--radius-md);
  overflow: hidden; flex-shrink: 0;
  box-shadow: 0 4rpx 20rpx rgba(192,139,92,0.15);
}
.hero-photo {
  width: 100%; height: 100%;
}
.hero-info {
  flex: 1; display: flex; flex-direction: column; gap: var(--spacing-xs);
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 6rpx;
  background: var(--color-ai-bg); border-radius: var(--radius-capsule);
  padding: 6rpx var(--spacing-sm); align-self: flex-start;
}
.hero-badge-icon { font-size: var(--font-xs); }
.hero-badge-text { font-size: var(--font-xs); color: var(--color-ai); font-weight: 700; }
.hero-conclusion {
  font-size: var(--font-md); font-weight: 800; color: var(--color-primary);
  line-height: 1.4;
}

/* ====== 2. 四维特征 ====== */
.feat-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-sm);
}
.feat-card {
  padding: var(--spacing-md); display: flex; flex-direction: column; align-items: center;
  border-radius: var(--radius-md);
  transition: transform 0.2s;
}
.feat-card:active { transform: scale(0.97); }
.feat-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%; margin-bottom: var(--spacing-xs);
}
.feat-label {
  font-size: var(--font-xs); color: var(--color-text-sub); font-weight: 500;
  margin-bottom: var(--spacing-xs); letter-spacing: 2rpx;
}
.feat-value {
  font-size: var(--font-base); font-weight: 700; color: var(--color-text-title);
  text-align: center; line-height: 1.4;
}

/* ====== 3. 分析详情 ====== */
.analysis-card {
  position: relative; padding: var(--spacing-md) var(--spacing-md) var(--spacing-md) var(--spacing-lg);
  background: var(--bg-card); border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.analysis-deco {
  position: absolute; left: 0; top: var(--spacing-sm); bottom: var(--spacing-sm); width: 6rpx;
  background: linear-gradient(180deg, var(--color-primary), var(--color-ai));
  border-radius: 3rpx;
}
.analysis-text {
  font-size: var(--font-base); color: var(--color-text-main); line-height: 2;
}

/* ====== 4. 产品推荐（独立卡片） ====== */
.rx-intro {
  font-size: var(--font-sm); color: var(--color-text-sub); margin-bottom: var(--spacing-md);
  display: block; line-height: 1.6;
}

/* 产品卡片列表容器 */
.rx-product-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

/* === 单个产品卡片 === */
.rx-product-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  position: relative;
}
.rx-product-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

/* --- 顶部视觉区：图片 + 推荐理由 --- */
.rx-card-visual {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
  padding: var(--spacing-md) var(--spacing-md) var(--spacing-md);
}

.rx-card-img-wrap {
  width: 150rpx; height: 150rpx;
  border-radius: 18rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(145deg, #f8f5f0, #ede8e0);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.rx-card-img {
  width: 100%; height: 100%;
}
.rx-card-img-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
}
.rx-card-img-emoji {
  font-size: 56rpx;
}

/* 推荐理由（图片右侧） */
.rx-card-reason {
  flex: 1;
  min-width: 0;
}
.rx-card-desc {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  line-height: 1.7;
  display: block;
}

/* --- 下方信息区 --- */
.rx-card-bottom {
  padding: 0 var(--spacing-md) var(--spacing-md);
}

/* 第一行：产品名(左) + 体质匹配标签(右) */
.rx-card-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}
.rx-card-name {
  font-size: var(--font-md); font-weight: 800; color: var(--color-text-title);
  line-height: 1.3;
  flex: 1;
  min-width: 0;
}

/* 体质匹配标签 */
.rx-match-badge {
  display: inline-flex; align-items: center; gap: 6rpx;
  background: linear-gradient(135deg, #C08B5C, #A67443);
  border-radius: 100rpx;
  padding: 6rpx var(--spacing-sm);
  flex-shrink: 0;
  margin-left: var(--spacing-sm);
}
.rx-match-icon {
  font-size: 16rpx; color: #fff;
}
.rx-match-text {
  font-size: var(--font-xs); color: #fff; font-weight: 700;
  letter-spacing: 1rpx;
}

/* 第二行：价格 + CTA */
.rx-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rx-card-price-group {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.rx-card-price-symbol {
  font-size: var(--font-sm); color: var(--color-primary); font-weight: 700;
}
.rx-card-price {
  font-size: var(--font-xl); color: var(--color-primary); font-weight: 800;
  letter-spacing: -1rpx;
}
.rx-card-orig {
  font-size: var(--font-xs); color: var(--color-text-muted);
  text-decoration: line-through;
  margin-left: var(--spacing-xs);
}

/* CTA 按钮 */
.rx-card-cta {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: 100rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light, #ff8a65));
  color: #fff;
  font-size: var(--font-sm);
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(192,139,92,0.2);
  transition: transform 0.2s ease;
}
.rx-card-cta:active {
  transform: scale(0.96);
}
.rx-card-cta-arrow {
  font-size: var(--font-xs);
}

/* ====== 5. 调理建议 ====== */
.tip-list { display: flex; flex-direction: column; gap: var(--spacing-sm); }
.tip-item { display: flex; align-items: flex-start; gap: var(--spacing-xs); }
.tip-num {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: var(--color-eco-bg); color: var(--color-eco-dark);
  font-size: var(--font-xs); font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 4rpx;
}
.tip-text {
  font-size: var(--font-base); line-height: 1.7; color: var(--color-text-main); flex: 1;
}

/* ====== 免责声明 ====== */
.disclaimer {
  margin: var(--spacing-md) 0; padding: var(--spacing-md);
  background: rgba(0,0,0,0.02); border-radius: var(--radius-md);
  text-align: center;
}
.disclaimer text {
  font-size: var(--font-xs); color: var(--color-text-muted); line-height: 1.6;
}

/* ====== 底部操作栏 ====== */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: var(--spacing-sm); padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  background: rgba(250,246,241,0.92);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0,0,0,0.04);
  z-index: 100;
}
.btn-retry {
  flex: 1; height: 88rpx; display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-capsule);
  border: 2rpx solid rgba(0,0,0,0.08);
  color: var(--color-text-main); font-size: var(--font-base); font-weight: 600;
  background: var(--bg-card);
}
.btn-share {
  flex: 2; height: 88rpx; display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-capsule); border: none; padding: 0;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff; font-size: var(--font-base); font-weight: 700;
  box-shadow: var(--shadow-float); line-height: 88rpx;
}
.btn-share::after { display: none; }

/* ====== 历史列表 ====== */
.hist-list { padding: 0; }
.hist-item {
  display: flex; align-items: center; padding: var(--spacing-md);
  border-radius: var(--radius-md); margin-bottom: var(--spacing-sm);
}
.hist-img {
  width: 100rpx; height: 100rpx; border-radius: var(--radius-sm);
  margin-right: var(--spacing-md); background: #f0f0f0;
}
.hist-info {
  flex: 1; display: flex; flex-direction: column; gap: 6rpx;
}
.hist-name {
  font-size: var(--font-base); font-weight: 700; color: var(--color-text-title);
}
.hist-date { font-size: var(--font-sm); color: var(--color-text-sub); }
.hist-arrow {
  font-size: var(--font-lg); color: var(--color-text-muted); font-weight: 300;
}
.hist-empty {
  text-align: center; padding: 80rpx 0; color: var(--color-text-sub); font-size: var(--font-base);
}
