<!--pages/tongue-report/tongue-report.wxml-->
<view class="page-report">
  <view class="bg-deco deco-1"></view>
  <view class="bg-deco deco-2"></view>

  <!-- 加载状态 -->
  <view class="loader-wrap" wx:if="{{loading}}">
    <view class="loader-spinner"></view>
    <text class="loader-text">正在加载报告…</text>
  </view>

  <block wx:if="{{!loading && mode === 'report' && report}}">
    <view class="report-content">

      <!-- 顶部信息区 -->
      <view class="hero-section animate-fade-up">
        <view class="hero-header">
          <text class="hero-label">舌象分析报告</text>
          <text class="hero-date">{{createdAtStr}}</text>
        </view>

        <view class="hero-card">
          <view class="hero-photo-wrap">
            <image class="hero-photo" src="{{report.imageFileId}}" mode="aspectFill"></image>
          </view>
          <view class="hero-info">
            <view class="hero-badge">
              <text class="hero-badge-icon">✨</text>
              <text class="hero-badge-text">AI 智能分析</text>
            </view>
            <text class="hero-conclusion">{{report.result.conclusion || '分析完成'}}</text>
          </view>
        </view>
      </view>

      <!-- 四维舌象特征 -->
      <view class="section animate-fade-up" style="animation-delay:.08s">
        <view class="section-header">
          <text class="section-title">舌象特征</text>
          <text class="section-subtitle">基于 AI 识别的四大维度</text>
        </view>
        <view class="feat-grid">
          <view class="feat-card">
            <view class="feat-icon-wrap" style="background:#FEF2F2">
              <view class="feat-dot" style="background:#EF4444"></view>
            </view>
            <view class="feat-meta">
              <text class="feat-label">舌色</text>
              <text class="feat-value">{{report.result.tongueColor || report.result.features.color || '正常'}}</text>
            </view>
          </view>
          <view class="feat-card">
            <view class="feat-icon-wrap" style="background:#F0FDF4">
              <view class="feat-dot" style="background:#22C55E"></view>
            </view>
            <view class="feat-meta">
              <text class="feat-label">舌苔</text>
              <text class="feat-value">{{report.result.tongueCoating || report.result.features.coating || '正常'}}</text>
            </view>
          </view>
          <view class="feat-card">
            <view class="feat-icon-wrap" style="background:#FFFBEB">
              <view class="feat-dot" style="background:#EAB308"></view>
            </view>
            <view class="feat-meta">
              <text class="feat-label">舌形</text>
              <text class="feat-value">{{report.result.tongueShape || report.result.features.shape || '正常'}}</text>
            </view>
          </view>
          <view class="feat-card">
            <view class="feat-icon-wrap" style="background:#EFF6FF">
              <view class="feat-dot" style="background:#3B82F6"></view>
            </view>
            <view class="feat-meta">
              <text class="feat-label">润燥</text>
              <text class="feat-value">{{report.result.moisture || report.result.features.moisture || '适中'}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 分析详情 -->
      <view class="section animate-fade-up" style="animation-delay:.14s" wx:if="{{report.result.analysis_details}}">
        <view class="section-header">
          <text class="section-title">分析详情</text>
          <text class="section-subtitle">AI 综合研判</text>
        </view>
        <view class="analysis-card">
          <view class="analysis-quote">“</view>
          <text class="analysis-text">{{report.result.analysis_details}}</text>
        </view>
      </view>

      <!-- 产品推荐 -->
      <view class="section animate-fade-up" style="animation-delay:.20s" wx:if="{{recommendGroups.length > 0}}">
        <view class="section-header">
          <text class="section-title">为您甄选</text>
          <text class="section-subtitle">根据舌象匹配的调理方案</text>
        </view>

        <view class="rx-product-list">
          <block wx:for="{{recommendGroups}}" wx:key="category">
            <view class="rx-group" wx:if="{{item.items.length > 0}}">
              <text class="rx-group-title">{{item.category}}</text>
              <view class="rx-group-list">
                <view class="rx-product-card card-press"
                      wx:for="{{item.items}}" wx:for-item="prod" wx:key="product_name"
                      bindtap="goToProduct" data-id="{{prod.productId}}">

                  <view class="rx-image-zone">
                    <image class="rx-img" src="{{prod.image}}" mode="aspectFill" wx:if="{{prod.image}}"></image>
                    <view class="rx-img-placeholder" wx:else>
                      <text class="rx-img-emoji">🧴</text>
                    </view>
                    <view class="rx-match-tag">
                      <text>体质匹配</text>
                    </view>
                  </view>

                  <view class="rx-info-zone">
                    <view class="rx-info-top">
                      <text class="rx-name">{{prod.product_name}}</text>
                      <text class="rx-reason" wx:if="{{prod.efficacy_match}}">{{prod.efficacy_match}}</text>
                      <text class="rx-reason" wx:else>根据您的舌象特征，该产品与您当前体质高度匹配</text>
                    </view>

                    <view class="rx-info-bottom">
                      <view class="rx-price-wrap">
                        <text class="rx-symbol">¥</text>
                        <text class="rx-price">{{prod.priceYuan}}</text>
                        <text class="rx-origin" wx:if="{{prod.originalPriceYuan}}">¥{{prod.originalPriceYuan}}</text>
                      </view>
                      <view class="rx-action">了解详情</view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>

      <!-- 调理建议 -->
      <view class="section animate-fade-up" style="animation-delay:.28s" wx:if="{{report.result.suggestions.length > 0}}">
        <view class="section-header">
          <text class="section-title">调理建议</text>
          <text class="section-subtitle">日常生活中的改善方向</text>
        </view>
        <view class="tip-list">
          <view class="tip-item" wx:for="{{report.result.suggestions}}" wx:key="*this">
            <view class="tip-icon">
              <text>{{['💡','🍵','🧘','🌿','🛁','✨'][index % 6]}}</text>
            </view>
            <text class="tip-text">{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 免责声明 -->
      <view class="disclaimer animate-fade-up" style="animation-delay:.32s">
        <text class="disclaimer-icon">⚕️</text>
        <text class="disclaimer-text">本报告由 AI 辅助分析，仅供参考，不作为医疗诊断依据。如有不适请及时就医。</text>
      </view>

    </view>
  </block>

  <!-- 底部操作栏 -->
  <view class="bottom-bar animate-fade-up" style="animation-delay:.36s" wx:if="{{!loading && mode === 'report' && report}}">
    <view class="btn-retry card-press" bindtap="goAnalyzeAgain">
      <text>重新分析</text>
    </view>
    <button class="btn-share card-press" open-type="share">
      <text>分享给好友</text>
    </button>
  </view>

  <!-- 历史列表 -->
  <block wx:if="{{!loading && mode === 'history'}}">
    <view class="report-content">
      <view class="section-header animate-fade-up" style="margin-top:40rpx">
        <text class="section-title">分析记录</text>
        <text class="section-subtitle">History</text>
      </view>
      <view class="hist-list">
        <view class="hist-item card-float card-press animate-fade-up" wx:for="{{historyList}}" wx:key="_id" bindtap="viewHistoryReport" data-id="{{item._id}}" style="animation-delay:{{index*0.05}}s">
          <image class="hist-img" src="{{item.imageFileId}}" mode="aspectFill"></image>
          <view class="hist-info">
            <text class="hist-name">舌象分析报告</text>
            <text class="hist-date">{{item.createdAtStr}}</text>
          </view>
          <text class="hist-arrow">›</text>
        </view>
        <view class="hist-empty" wx:if="{{historyList.length === 0}}">
          <text>暂无分析记录</text>
        </view>
      </view>
    </view>
  </block>
</view>
