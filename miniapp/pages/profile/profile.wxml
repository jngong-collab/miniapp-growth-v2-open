<!--pages/profile/profile.wxml-->
<view class="page-profile">
  <!-- 顶部渐变背景 -->
  <view class="profile-header-bg"></view>

  <!-- 已登录会员卡片 -->
  <view class="member-card-wrap animate-fade-up" wx:if="{{isLoggedIn}}">
    <view class="member-card card-press">
      <view class="card-shine"></view>
      <view class="card-content">
        <view class="card-row-top">
          <view class="user-info">
            <view class="avatar" wx:if="{{userInfo.avatarUrl}}">
              <image src="{{userInfo.avatarUrl}}" mode="aspectFill" style="width:100%;height:100%"></image>
            </view>
            <view class="avatar avatar-placeholder" wx:else>👤</view>
            <view class="user-meta">
              <text class="user-name">{{userInfo.nickName || '会员用户'}}</text>
              <view class="level-badge">
                <text class="badge-icon">✦</text>
                <text>{{levelLabel}}</text>
              </view>
              <view class="phone-badge" wx:if="{{userInfo.phone}}">
                <text class="phone-icon">📱</text>
                <text>{{userInfo.phone}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="card-row-bottom">
          <view class="balance-info">
            <text class="balance-label">账户余额</text>
            <text class="balance-amount">¥{{balanceYuan}}</text>
          </view>
          <text class="card-brand">BABY SPA</text>
        </view>
        <button
          class="logout-btn card-press"
          wx:if="{{isLoggedIn}}"
          bindtap="doLogout"
        >退出登录</button>
      </view>
    </view>
  </view>

  <!-- 未登录游客卡片 -->
  <view class="member-card-wrap animate-fade-up" wx:else>
    <view class="guest-showcase-card">
      <view class="guest-showcase-glow"></view>
      <view class="guest-showcase-content">
        <view class="guest-showcase-badge">会员中心</view>
        <text class="guest-showcase-title">未登录</text>
        <text class="guest-showcase-subtitle">授权手机号后，可查看订单、套餐、邀请收益和 AI 舌象记录。</text>

        <view class="guest-benefit-list">
          <view class="guest-benefit-item">
            <view class="guest-benefit-icon">📦</view>
            <view class="guest-benefit-meta">
              <text class="guest-benefit-name">订单与套餐</text>
              <text class="guest-benefit-desc">登录后同步查看购买记录与可用服务</text>
            </view>
          </view>
          <view class="guest-benefit-item">
            <view class="guest-benefit-icon">💰</view>
            <view class="guest-benefit-meta">
              <text class="guest-benefit-name">邀请收益</text>
              <text class="guest-benefit-desc">分享后可查看收益与好友数据</text>
            </view>
          </view>
          <view class="guest-benefit-item">
            <view class="guest-benefit-icon">🌿</view>
            <view class="guest-benefit-meta">
              <text class="guest-benefit-name">AI 舌象记录</text>
              <text class="guest-benefit-desc">保存历史分析结果，持续跟踪调理变化</text>
            </view>
          </view>
        </view>

        <block wx:if="{{!privacyChecked}}">
          <view class="guest-privacy-card guest-privacy-loading">
            <text class="guest-privacy-title">正在检查隐私授权状态…</text>
            <text class="guest-privacy-desc">首次使用手机号登录前，需要先确认微信侧的隐私授权状态。</text>
          </view>
        </block>
        <block wx:elif="{{needPrivacyAuthorization}}">
          <view class="guest-privacy-card">
            <text class="guest-privacy-title">登录前请先阅读并同意隐私指引</text>
            <text class="guest-privacy-desc">首次使用手机号登录前，请先查看并同意{{privacyContractName}}。</text>
            <view class="guest-privacy-actions">
              <button class="guest-privacy-link-btn" bindtap="openPrivacyContract">查看{{privacyContractName}}</button>
              <button
                id="profile-privacy-agree-btn"
                class="guest-privacy-agree-btn"
                open-type="agreePrivacyAuthorization"
                bindagreeprivacyauthorization="onAgreePrivacyAuthorization"
              >同意隐私指引</button>
            </view>
          </view>
        </block>
        <block wx:elif="{{privacyDeclarationMissing}}">
          <view class="guest-privacy-card">
            <text class="guest-privacy-title">当前版本暂无法使用手机号登录</text>
            <text class="guest-privacy-desc">微信检测到当前版本未完成手机号相关隐私声明，已阻止授权。请更新到完成隐私指引配置的版本后再试。</text>
            <view class="guest-privacy-actions">
              <button class="guest-privacy-link-btn" bindtap="openPrivacyContract">查看{{privacyContractName}}</button>
              <button class="guest-privacy-agree-btn" bindtap="retryPrivacyStateCheck">重新检查</button>
            </view>
          </view>
        </block>
        <button
          wx:else
          class="guest-login-btn"
          open-type="getPhoneNumber"
          bind:getphonenumber="onGetPhoneNumber"
          loading="{{loggingIn}}"
        >{{loggingIn ? '登录中...' : '微信授权手机号登录'}}</button>
      </view>
    </view>
  </view>

  <!-- 数据统计条 -->
  <view class="stat-bar card animate-fade-up" style="animation-delay: 0.08s" wx:if="{{isLoggedIn}}">
    <view class="stat-cell card-press" bindtap="goToOrders" data-status="all">
      <text class="stat-val">{{orderCount || 0}}</text>
      <text class="stat-label">全部订单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-cell card-press" bindtap="goToPackage">
      <text class="stat-val stat-eco">{{packageCount || 0}}</text>
      <text class="stat-label">有效套餐</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-cell card-press" bindtap="goToFission">
      <text class="stat-val stat-gold">{{invitedCount || 0}}</text>
      <text class="stat-label">已邀好友</text>
    </view>
  </view>

  <!-- 主体内容 -->
  <view class="profile-body">
    <view class="section-block animate-fade-up" style="animation-delay: 0.1s" wx:if="{{isLoggedIn}}">
      <view class="section-head">
        <text class="section-title">头像与昵称</text>
        <text class="section-more">用于个人中心、邀请记录和后台客户展示</text>
      </view>
      <view class="profile-editor">
        <button
          class="profile-avatar-picker"
          bindtap="chooseProfileAvatar"
        >
          <image
            class="profile-avatar-image"
            wx:if="{{profileDraftAvatarUrl}}"
            src="{{profileDraftAvatarUrl}}"
            mode="aspectFill"
          ></image>
          <view class="profile-avatar-fallback" wx:else>👤</view>
          <view class="profile-avatar-tip">点击更换头像</view>
        </button>
        <form class="profile-editor-form" bindsubmit="saveProfile">
          <input
            class="profile-name-input"
            name="nickName"
            type="nickname"
            placeholder="请输入昵称"
            maxlength="20"
            value="{{profileDraftNickName}}"
            bindinput="onProfileNicknameInput"
            bindblur="onProfileNicknameBlur"
          />
          <text class="profile-editor-desc">头像昵称将展示在个人中心、邀请记录和门店后台客户列表中。</text>
          <button
            class="profile-save-btn"
            form-type="submit"
            loading="{{profileSaving}}"
            disabled="{{profileSaving || !profileDirty}}"
          >{{profileSaving ? '保存中...' : (profileDirty ? '保存资料' : '资料已同步')}}</button>
        </form>
      </view>
    </view>

    <!-- 订单快捷入口 -->
    <view class="section-block animate-fade-up" style="animation-delay: 0.14s" wx:if="{{isLoggedIn}}">
      <view class="section-head">
        <text class="section-title">我的订单</text>
        <text class="section-more" bindtap="goToOrders" data-status="all">查看全部 ›</text>
      </view>
      <view class="order-grid">
        <view class="order-entry card-press" bindtap="goToOrders" data-status="pending">
          <view class="entry-icon-wrap" style="background:#FFF5F0">
            <text class="entry-icon">💳</text>
          </view>
          <text class="entry-text">待支付</text>
        </view>
        <view class="order-entry card-press" bindtap="goToOrders" data-status="paid">
          <view class="entry-icon-wrap" style="background:#F0F5F1">
            <text class="entry-icon">✅</text>
          </view>
          <text class="entry-text">已支付</text>
        </view>
        <view class="order-entry card-press" bindtap="goToPackage">
          <view class="entry-icon-wrap" style="background:#F5EFE8">
            <text class="entry-icon">🎫</text>
          </view>
          <text class="entry-text">去核销</text>
        </view>
        <view class="order-entry card-press" bindtap="goToOrders" data-status="refund">
          <view class="entry-icon-wrap" style="background:#FAF7F2">
            <text class="entry-icon">↩️</text>
          </view>
          <text class="entry-text">退款</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="section-block animate-fade-up" style="animation-delay: 0.2s" wx:if="{{isLoggedIn}}">
      <view class="menu-row card-press" bindtap="goToFission">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#F5EFE8">💰</view>
          <text class="menu-label">分享赚钱</text>
        </view>
        <view class="menu-row-right">
          <text class="menu-extra highlight" wx:if="{{balanceYuan && balanceYuan !== '0.0'}}">累计赚 ¥{{balanceYuan}}</text>
          <text class="menu-chevron">›</text>
        </view>
      </view>
      <view class="menu-row card-press" bindtap="goToTongue">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#EDF2EF">🌿</view>
          <text class="menu-label">{{tongueMenuLabel}}</text>
        </view>
        <view class="menu-row-right">
          <text class="menu-extra" wx:if="{{tongueCountLabel}}">{{tongueCountLabel}}</text>
          <text class="menu-chevron">›</text>
        </view>
      </view>
    </view>

    <!-- 门店服务 -->
    <view class="section-block animate-fade-up" style="animation-delay: 0.26s">
      <view class="menu-row card-press" bindtap="callStore">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#FAF7F2">📞</view>
          <text class="menu-label">联系门店</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
      <view class="menu-row card-press" bindtap="openMap" wx:if="{{storeInfo}}">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#FAF7F2">📍</view>
          <text class="menu-label">门店导航</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
    </view>

    <!-- 管理员/员工入口 -->
    <view class="section-block animate-fade-up" style="animation-delay: 0.32s" wx:if="{{canEnterWorkbench}}">
      <view class="section-head" style="margin-bottom:0">
        <text class="section-title">{{role === 'admin' ? '门店管理' : '员工工作台'}}</text>
      </view>
      <view class="menu-row card-press" bindtap="goToWorkbench">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#EDF2EF">📊</view>
          <text class="menu-label">门店工作台</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
      <view class="menu-row card-press" bindtap="goToVerify" wx:if="{{permissions && permissions.indexOf('verify') !== -1}}">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#F0F5F1">🔑</view>
          <text class="menu-label">核销中心</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
      <view class="menu-row card-press" bindtap="goToStaffManage" wx:if="{{role === 'admin'}}">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#EDF2EF">👥</view>
          <text class="menu-label">员工管理</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
    </view>

    <view class="page-footer animate-fade-up" style="animation-delay: 0.38s">v{{version}} · 浴小主</view>
  </view>
</view>
