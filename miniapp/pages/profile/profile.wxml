<!--pages/profile/profile.wxml-->
<view class="page-profile">
  <!-- 顶部渐变背景 -->
  <view class="profile-header-bg"></view>

  <!-- 会员卡片 -->
  <view class="member-card-wrap animate-fade-up">
    <view class="member-card card-press">
      <view class="card-shine"></view>
      <view class="card-content">
        <view class="card-row-top">
          <view class="user-info">
            <view class="avatar" wx:if="{{userInfo.avatarUrl}}">
              <image src="{{userInfo.avatarUrl}}" mode="aspectFill" style="width:100%;height:100%"></image>
            </view>
            <view class="avatar avatar-placeholder" wx:else>👤</view>
            <view class="user-meta">
              <text class="user-name">{{userInfo.nickName || '微信用户'}}</text>
              <view class="level-badge">
                <text class="badge-icon">✦</text>
                <text>{{levelLabel}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="card-row-bottom">
          <view class="balance-info">
            <text class="balance-label">账户余额</text>
            <text class="balance-amount">¥{{balanceYuan}}</text>
          </view>
          <text class="card-brand">BABY SPA</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 数据统计条 -->
  <view class="stat-bar card animate-fade-up" style="animation-delay: 0.08s">
    <view class="stat-cell card-press" bindtap="goToOrders" data-status="all">
      <text class="stat-val">{{orderCount || 0}}</text>
      <text class="stat-label">全部订单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-cell card-press" bindtap="goToPackage">
      <text class="stat-val stat-eco">{{packageCount || 0}}</text>
      <text class="stat-label">有效套餐</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-cell card-press" bindtap="goToFission">
      <text class="stat-val stat-gold">{{invitedCount || 0}}</text>
      <text class="stat-label">已邀好友</text>
    </view>
  </view>

  <!-- 主体内容 -->
  <view class="profile-body">

    <!-- 订单快捷入口 -->
    <view class="section-block animate-fade-up" style="animation-delay: 0.14s">
      <view class="section-head">
        <text class="section-title">我的订单</text>
        <text class="section-more" bindtap="goToOrders" data-status="all">查看全部 ›</text>
      </view>
      <view class="order-grid">
        <view class="order-entry card-press" bindtap="goToOrders" data-status="pending">
          <view class="entry-icon-wrap" style="background:#FFF5F0">
            <text class="entry-icon">💳</text>
          </view>
          <text class="entry-text">待支付</text>
        </view>
        <view class="order-entry card-press" bindtap="goToOrders" data-status="paid">
          <view class="entry-icon-wrap" style="background:#F0F5F1">
            <text class="entry-icon">✅</text>
          </view>
          <text class="entry-text">已支付</text>
        </view>
        <view class="order-entry card-press" bindtap="goToPackage">
          <view class="entry-icon-wrap" style="background:#F5EFE8">
            <text class="entry-icon">🎫</text>
          </view>
          <text class="entry-text">去核销</text>
        </view>
        <view class="order-entry card-press" bindtap="goToOrders" data-status="refund">
          <view class="entry-icon-wrap" style="background:#FAF7F2">
            <text class="entry-icon">↩️</text>
          </view>
          <text class="entry-text">退款</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="section-block animate-fade-up" style="animation-delay: 0.2s">
      <view class="menu-row card-press" bindtap="goToFission">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#F5EFE8">💰</view>
          <text class="menu-label">分享赚钱</text>
        </view>
        <view class="menu-row-right">
          <text class="menu-extra highlight" wx:if="{{balanceYuan && balanceYuan !== '0.0'}}">累计赚 ¥{{balanceYuan}}</text>
          <text class="menu-chevron">›</text>
        </view>
      </view>
      <view class="menu-row card-press" bindtap="goToTongue">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#EDF2EF">🌿</view>
          <text class="menu-label">{{tongueMenuLabel}}</text>
        </view>
        <view class="menu-row-right">
          <text class="menu-extra" wx:if="{{tongueCountLabel}}">{{tongueCountLabel}}</text>
          <text class="menu-chevron">›</text>
        </view>
      </view>
    </view>

    <!-- 门店服务 -->
    <view class="section-block animate-fade-up" style="animation-delay: 0.26s">
      <view class="menu-row card-press" bindtap="callStore">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#FAF7F2">📞</view>
          <text class="menu-label">联系门店</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
      <view class="menu-row card-press" bindtap="openMap" wx:if="{{storeInfo}}">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#FAF7F2">📍</view>
          <text class="menu-label">门店导航</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
    </view>

    <!-- 管理员/员工入口 -->
    <view class="section-block animate-fade-up" style="animation-delay: 0.32s" wx:if="{{canEnterWorkbench}}">
      <view class="section-head" style="margin-bottom:0">
        <text class="section-title">{{role === 'admin' ? '门店管理' : '员工工作台'}}</text>
      </view>
      <view class="menu-row card-press" bindtap="goToWorkbench">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#EDF2EF">📊</view>
          <text class="menu-label">门店工作台</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
      <view class="menu-row card-press" bindtap="goToVerify" wx:if="{{permissions && permissions.indexOf('verify') !== -1}}">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#F0F5F1">🔑</view>
          <text class="menu-label">核销中心</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
      <view class="menu-row card-press" bindtap="goToStaffManage" wx:if="{{role === 'admin'}}">
        <view class="menu-row-left">
          <view class="menu-icon" style="background:#EDF2EF">👥</view>
          <text class="menu-label">员工管理</text>
        </view>
        <text class="menu-chevron">›</text>
      </view>
    </view>

    <view class="page-footer animate-fade-up" style="animation-delay: 0.38s">v{{version}} · 浴小主</view>
  </view>
</view>
