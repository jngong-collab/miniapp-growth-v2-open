/* pages/profile/profile.wxss — 现代东方会员中心 */

.page-profile {
  min-height: 100vh;
  background: var(--bg-page);
  position: relative;
  overflow-x: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}

.profile-header-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 480rpx;
  background: linear-gradient(180deg, var(--color-primary-bg) 0%, var(--bg-page) 100%);
  z-index: 0;
}

/* ====== 会员卡 ====== */
.member-card-wrap {
  position: relative;
  z-index: 2;
  padding: var(--spacing-md) var(--spacing-lg) 0;
}

.member-card {
  position: relative;
  width: 100%;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: linear-gradient(135deg, #D4A574, #B8916B, #8B6B4A);
  color: #fff;
  box-shadow: 0 20rpx 48rpx rgba(184,145,107,0.18);
}

.card-shine {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: repeating-linear-gradient(
    135deg,
    transparent, transparent 18px,
    rgba(255,255,255,0.04) 18px, rgba(255,255,255,0.04) 36px
  );
  pointer-events: none;
  z-index: 0;
}

.card-shine::after {
  content: '';
  position: absolute;
  top: -60%; left: -30%;
  width: 160%; height: 160%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.14), transparent 45%);
  pointer-events: none;
}

.card-content {
  position: relative;
  z-index: 1;
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xl);
}

.user-info { display: flex; align-items: center; }
.avatar {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.4);
  overflow: hidden;
  background: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-xl);
  flex-shrink: 0;
}

.user-meta { margin-left: var(--spacing-md); display: flex; flex-direction: column; gap: var(--spacing-xs); }
.user-name {
  font-size: var(--font-md); font-weight: 700;
  letter-spacing: 0.5rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.12);
}

.level-badge {
  display: inline-flex; align-items: center;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(8px);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-capsule);
  font-size: var(--font-xs); font-weight: 600;
  border: 1rpx solid rgba(255,255,255,0.3);
  align-self: flex-start;
}

.badge-icon { margin-right: 4rpx; font-size: var(--font-xs); }

.card-row-bottom {
  display: flex; justify-content: space-between; align-items: flex-end;
}

.balance-info { display: flex; flex-direction: column; }
.balance-label { font-size: var(--font-xs); opacity: 0.85; margin-bottom: 4rpx; }
.balance-amount {
  font-size: 44rpx; font-weight: 800; line-height: 1;
  text-shadow: 0 3rpx 10rpx rgba(0,0,0,0.12);
  letter-spacing: -1rpx;
}

.card-brand {
  font-size: var(--font-sm); font-weight: 800;
  letter-spacing: 4rpx;
  color: rgba(255,255,255,0.25);
  text-transform: uppercase;
}

/* ====== 统计条 ====== */
.stat-bar {
  position: relative; z-index: 3;
  margin: -24rpx var(--spacing-lg) var(--spacing-md);
  display: flex; align-items: center;
  padding: var(--spacing-md) 0;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--color-border);
}

.stat-cell {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  transition: transform 0.2s ease;
}

.stat-cell:active { transform: scale(0.95); opacity: 0.8; }

.stat-val {
  font-size: var(--font-lg); font-weight: 800; margin-bottom: 6rpx;
  color: var(--color-text-title);
}

.stat-val.stat-eco { color: var(--color-eco-dark); }
.stat-val.stat-gold { color: var(--color-gold); }

.stat-label { font-size: var(--font-xs); color: var(--color-text-sub); font-weight: 500; }

.stat-divider {
  width: 1rpx; height: 40rpx;
  background: linear-gradient(to bottom, transparent, var(--color-border), transparent);
}

/* ====== 主体 ====== */
.profile-body { padding: 0 var(--spacing-lg); position: relative; z-index: 2; }

.section-block {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-md);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
}

.section-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-name { font-size: var(--font-md); font-weight: 700; color: var(--color-text-title); }
.section-more { font-size: var(--font-sm); color: var(--color-text-sub); font-weight: 500; }

/* 订单快捷入口 */
.order-grid { display: flex; justify-content: space-around; }
.order-entry {
  display: flex; flex-direction: column; align-items: center;
  padding: var(--spacing-xs) 0;
  transition: transform 0.2s ease;
}

.order-entry:active { transform: scale(0.9); opacity: 0.8; }

.entry-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-sm);
}

.entry-icon { font-size: 40rpx; }
.entry-text { font-size: var(--font-xs); font-weight: 500; color: var(--color-text-main); }

/* 菜单行 */
.menu-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border);
  transition: opacity 0.2s ease;
}

.menu-row:last-child { border-bottom: none; }
.menu-row:active { opacity: 0.6; }
.menu-row-left { display: flex; align-items: center; }

.menu-icon {
  width: 48rpx; height: 48rpx;
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-sm); margin-right: var(--spacing-md);
}

.menu-label {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-title);
}

.menu-row-right { display: flex; align-items: center; }
.menu-extra {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  margin-right: var(--spacing-xs);
  font-weight: 500;
}

.menu-extra.highlight { color: var(--color-primary-dark); }
.menu-chevron { font-size: var(--font-md); font-weight: 300; color: var(--color-text-muted); }

/* 手机号绑定 */
.phone-badge {
  display: inline-flex; align-items: center;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-capsule);
  font-size: var(--font-xs); font-weight: 500;
  border: 1rpx solid rgba(255,255,255,0.35);
  align-self: flex-start;
  margin-top: 6rpx;
  color: #fff;
}
.phone-icon { margin-right: 4rpx; font-size: var(--font-xs); }

.phone-bind-btn {
  display: inline-flex; align-items: center;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-capsule);
  font-size: var(--font-xs); font-weight: 600;
  border: 1rpx solid rgba(255,255,255,0.4);
  align-self: flex-start;
  margin-top: 6rpx;
  color: #fff;
  line-height: 1.4;
}
.phone-bind-btn::after { border: none; }

.login-tip {
  margin-top: 6rpx;
  font-size: var(--font-xs);
  color: rgba(255,255,255,0.8);
  line-height: 1.4;
}

.logout-btn {
  margin-top: 22rpx;
  height: 74rpx;
  border-radius: var(--radius-capsule);
  background: rgba(255,255,255,0.2);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.35);
  font-size: var(--font-xs);
  font-weight: 600;
}

.logout-btn::after { border: none; }

/* 页脚 */
.page-footer {
  text-align: center; font-size: var(--font-xs);
  padding: var(--spacing-xl) 0 var(--spacing-lg);
  color: var(--color-text-muted);
  letter-spacing: 1rpx;
}
