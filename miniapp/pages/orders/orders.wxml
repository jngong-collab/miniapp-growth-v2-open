<!--pages/orders/orders.wxml-->
<view class="orders-page">
  <scroll-view class="filter-scroll" scroll-x="true" show-scrollbar="false">
    <view class="filter-row">
      <view
        wx:for="{{filters}}"
        wx:key="key"
        class="filter-chip {{activeStatus === item.key ? 'filter-chip-active' : ''}}"
        data-status="{{item.key}}"
        bindtap="switchStatus"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="empty-block" wx:if="{{!loading && !orders.length}}">
    <text class="empty-icon">🍃</text>
    <text class="empty-title">还没有符合条件的订单</text>
    <text class="empty-desc">参与活动、购买体验项目后会显示在这里</text>
  </view>

  <view class="order-list" wx:else>
    <view class="order-card animate-fade-up" wx:for="{{orders}}" wx:key="_id" style="animation-delay: {{index * 0.05}}s">
      <view class="card-head">
        <view>
          <text class="order-title">{{item.displayProductName}}</text>
          <text class="order-no">{{item.orderNo}}</text>
        </view>
        <text class="status-tag">{{item.statusLabel}}</text>
      </view>
      <view class="card-meta">
        <text>下单时间 {{item.createdAtText}}</text>
        <text>数量 {{item.quantity || 1}} 件</text>
      </view>
      <view class="order-items-preview" wx:if="{{item.items && item.items.length}}">
        <view class="order-item-row" wx:for="{{item.items}}" wx:key="productId">
          <text class="order-item-name">{{item.productName}}</text>
          <text class="order-item-meta">×{{item.quantity}}</text>
        </view>
      </view>
      <view class="card-bottom">
        <view class="price-box">
          <text class="price-label">实付</text>
          <text class="price-value">¥{{item.payAmountYuan}}</text>
        </view>
        <view class="action-group">
          <button
            wx:if="{{item.canPay}}"
            class="ghost-btn pay-btn"
            data-id="{{item._id}}"
            bindtap="payOrder"
            size="mini"
          >
            去支付
          </button>
          <button
            wx:if="{{item.canRefund}}"
            class="ghost-btn"
            data-id="{{item._id}}"
            bindtap="requestRefund"
            size="mini"
          >
            申请退款
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
