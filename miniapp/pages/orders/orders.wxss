/* pages/orders/orders.wxss */

.orders-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.filter-scroll {
  white-space: nowrap;
  margin-bottom: var(--spacing-md);
}

.filter-row {
  display: inline-flex;
  gap: var(--spacing-sm);
}

.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-capsule);
  background: var(--bg-card);
  color: var(--color-text-sub);
  font-size: var(--font-sm);
  border: 1rpx solid var(--color-border);
  font-weight: 500;
}

.filter-chip-active {
  background: var(--color-text-title);
  color: #fff;
  border-color: var(--color-text-title);
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.order-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.card-head,
.card-meta,
.card-bottom {
  display: flex;
  justify-content: space-between;
  gap: var(--spacing-sm);
}

.card-head {
  align-items: flex-start;
  margin-bottom: var(--spacing-xs);
}

.card-meta {
  margin-top: var(--spacing-sm);
  color: var(--color-text-sub);
  font-size: var(--font-xs);
  padding-bottom: var(--spacing-md);
  border-bottom: 1rpx solid var(--color-border);
}

.card-bottom {
  margin-top: var(--spacing-md);
  align-items: center;
}

.action-group {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.order-title {
  display: block;
  font-size: var(--font-base);
  color: var(--color-text-title);
  font-weight: 700;
}

.order-no {
  display: block;
  margin-top: 4rpx;
  color: var(--color-text-muted);
  font-size: var(--font-xs);
}

.status-tag {
  padding: 6rpx 14rpx;
  border-radius: var(--radius-capsule);
  background: var(--color-primary-bg);
  color: var(--color-primary-dark);
  font-size: var(--font-xs);
  font-weight: 600;
  flex-shrink: 0;
}

.price-box {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-xs);
}

.price-label {
  color: var(--color-text-sub);
  font-size: var(--font-xs);
}

.price-value {
  color: var(--color-primary-dark);
  font-size: var(--font-lg);
  font-weight: 800;
}

.order-items-preview {
  margin-top: var(--spacing-sm);
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.order-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-sm);
}

.order-item-name {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--color-text-title);
}

.order-item-meta {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}

.ghost-btn {
  margin: 0;
  border-radius: var(--radius-capsule);
  border: 1rpx solid var(--color-border);
  background: var(--bg-page);
  color: var(--color-text-main);
  font-size: var(--font-xs);
  font-weight: 500;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 50rpx;
}

.pay-btn {
  border-color: rgba(184,145,107,0.2);
  background: rgba(184,145,107,0.10);
  color: var(--color-primary-dark);
}

.empty-block {
  padding: 160rpx var(--spacing-lg);
  text-align: center;
  color: var(--color-text-sub);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-sm);
  display: block;
}

.empty-title {
  display: block;
  font-size: var(--font-base);
  color: var(--color-text-title);
  font-weight: 700;
  margin-bottom: var(--spacing-xs);
}

.empty-desc {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}
