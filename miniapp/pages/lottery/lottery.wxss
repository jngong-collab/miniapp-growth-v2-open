/* pages/lottery/lottery.wxss */

.page-lottery {
  min-height: 100vh;
  background: linear-gradient(180deg, #D4A574 0%, #B8916B 30%, var(--bg-page) 60%);
  padding-bottom: 60rpx;
}

/* ====== 顶部 ====== */
.lottery-header {
  padding: var(--spacing-2xl) var(--spacing-lg) var(--spacing-lg);
  text-align: center;
  color: #fff;
}

.header-title {
  display: block;
  font-size: var(--font-xl);
  font-weight: 800;
  letter-spacing: 2rpx;
  margin-bottom: var(--spacing-xs);
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.12);
}

.header-sub {
  display: block;
  font-size: var(--font-sm);
  opacity: 0.9;
  margin-bottom: var(--spacing-md);
}

.chances-badge {
  display: inline-block;
  background: rgba(255,255,255,0.22);
  backdrop-filter: blur(10px);
  padding: var(--spacing-xs) var(--spacing-lg);
  border-radius: var(--radius-capsule);
  font-size: var(--font-sm);
  font-weight: 600;
  border: 1rpx solid rgba(255,255,255,0.35);
}

.chances-num {
  font-size: var(--font-md);
  font-weight: 800;
  color: #fff;
}

/* ====== 九宫格 ====== */
.grid-wrap {
  padding: 0 var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.grid-box {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  gap: var(--spacing-xs);
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-md);
  box-shadow: 0 16rpx 40rpx rgba(60,45,30,0.1);
  border: 1rpx solid var(--color-border);
}

.grid-cell {
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  transition: all 0.15s ease;
  position: relative;
  overflow: hidden;
  border: 1rpx solid var(--color-border);
  background: var(--bg-page);
}

.cell-icon { font-size: 44rpx; }
.cell-name {
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--color-text-title);
  text-align: center;
}

/* 高亮动画 */
.cell-active {
  box-shadow: 0 0 0 4rpx var(--color-primary), 0 8rpx 24rpx rgba(184,145,107,0.18);
  transform: scale(1.04);
}

.cell-active::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(184, 145, 107, 0.08);
  border-radius: var(--radius-md);
}

/* 中间按钮 */
.grid-btn {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary)) !important;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(184,145,107,0.22);
  border: none !important;
}

.grid-btn:active { transform: scale(0.95); }

.btn-text-big {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.btn-text-small {
  font-size: 20rpx;
  font-weight: 600;
  opacity: 0.9;
}

/* ====== 活动说明 ====== */
.lottery-info {
  margin: 0 var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.info-title {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-text-title);
  margin-bottom: var(--spacing-sm);
}

.info-item {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  line-height: 2;
  padding-left: var(--spacing-sm);
  position: relative;
}

.info-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--color-text-muted);
}

/* ====== 中奖弹窗 ====== */
.result-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.result-popup {
  width: 560rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 56rpx var(--spacing-xl) var(--spacing-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-float);
  animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes popIn {
  from { opacity: 0; transform: scale(0.7); }
  to { opacity: 1; transform: scale(1); }
}

.result-emoji { font-size: 80rpx; }
.result-title { font-size: var(--font-lg); font-weight: 800; color: var(--color-text-title); }
.result-name {
  font-size: var(--font-md); font-weight: 800;
  color: var(--color-primary-dark);
  background: var(--color-primary-bg);
  padding: var(--spacing-xs) var(--spacing-lg);
  border-radius: var(--radius-sm);
}

.result-hint { font-size: var(--font-sm); color: var(--color-text-sub); text-align: center; }

.result-btn {
  width: 100%;
  margin-top: var(--spacing-xs);
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  text-align: center;
  padding: var(--spacing-md);
  border-radius: var(--radius-capsule);
  font-size: var(--font-md);
  font-weight: 700;
}

.result-btn:active { opacity: 0.85; }
