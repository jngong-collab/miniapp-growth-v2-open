/* pages/lottery/lottery.wxss */

.page-lottery {
  min-height: 100vh;
  background: linear-gradient(180deg, #C08B5C 0%, #D4A574 35%, var(--bg-page) 65%);
  padding-bottom: 60rpx;
}

/* ====== 顶部 ====== */
.lottery-header {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
  color: #fff;
}
.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}
.header-sub {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}
.chances-badge {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(10px);
  padding: 10rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(255,255,255,0.4);
}
.chances-num {
  font-size: 32rpx;
  font-weight: 900;
  color: #F5D998;
}

/* ====== 九宫格 ====== */
.grid-wrap {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}
.grid-box {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  gap: 12rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 20rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.1);
}

.grid-cell {
  aspect-ratio: 1;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.15s ease;
  position: relative;
  overflow: hidden;
}
.cell-icon { font-size: 48rpx; }
.cell-name {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-text-title);
  text-align: center;
}

/* 高亮动画 */
.cell-active {
  box-shadow: 0 0 0 4rpx var(--color-primary), 0 8rpx 24rpx rgba(192, 139, 92, 0.3);
  transform: scale(1.05);
}
.cell-active::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(192, 139, 92, 0.08);
  border-radius: 20rpx;
}

/* 中间按钮 */
.grid-btn {
  background: linear-gradient(135deg, #D4A574, #C08B5C) !important;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(192, 139, 92, 0.4);
}
.grid-btn:active {
  transform: scale(0.95);
}
.btn-text-big {
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}
.btn-text-small {
  font-size: 20rpx;
  font-weight: 600;
  opacity: 0.9;
}

/* ====== 活动说明 ====== */
.lottery-info {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.info-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--color-text-title);
  margin-bottom: 16rpx;
}
.info-item {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-sub);
  line-height: 2;
  padding-left: 16rpx;
  position: relative;
}
.info-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--color-text-muted);
}

/* ====== 中奖弹窗 ====== */
.result-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.result-popup {
  width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 56rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
@keyframes popIn {
  from { opacity: 0; transform: scale(0.7); }
  to { opacity: 1; transform: scale(1); }
}

.result-emoji { font-size: 80rpx; }
.result-title { font-size: 36rpx; font-weight: 900; color: var(--color-text-title); }
.result-name {
  font-size: 32rpx; font-weight: 800;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 12rpx 32rpx;
  border-radius: 12rpx;
}
.result-hint { font-size: 24rpx; color: var(--color-text-sub); text-align: center; }
.result-btn {
  width: 100%;
  margin-top: 12rpx;
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
}
.result-btn:active { opacity: 0.8; }
