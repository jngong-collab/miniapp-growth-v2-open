<!--pages/tongue/tongue.wxml-->
<view class="page-tongue">
  <view class="bg-deco bg-deco-1"></view>
  <view class="bg-deco bg-deco-2"></view>

  <view class="tongue-content">
    <!-- idle 状态 -->
    <block wx:if="{{state === 'idle'}}">
      <!-- 步骤指引 -->
      <view class="process-strip animate-fade-up" style="animation-delay: 0.06s">
        <view class="process-step">
          <view class="step-num">1</view>
          <text class="step-label">{{stepLabels[0]}}</text>
        </view>
        <view class="step-line"></view>
        <view class="process-step">
          <view class="step-num">2</view>
          <text class="step-label">{{stepLabels[1]}}</text>
        </view>
        <view class="step-line"></view>
        <view class="process-step">
          <view class="step-num">3</view>
          <text class="step-label">{{stepLabels[2]}}</text>
        </view>
      </view>

      <!-- 宝宝信息卡 -->
      <view class="form-card card-float animate-fade-up" style="animation-delay: 0.1s">
        <view class="card-head">
          <view class="head-icon-bg" style="background:var(--color-eco-bg)">
            <text class="head-icon">👶</text>
          </view>
          <text class="head-title">宝宝信息</text>
        </view>
        <view class="form-body">
          <view class="form-row">
            <text class="f-label">宝宝年龄</text>
            <picker class="age-picker-box" bindchange="onAgeChange" value="{{ageIndex}}" range="{{ageList}}">
              <view class="f-picker">
                <text class="f-picker-text {{ageIndex >= 0 ? '' : 'f-picker-ph'}}">{{ageIndex >= 0 ? ageList[ageIndex] : '请选择'}}</text>
                <text class="f-picker-arrow">›</text>
              </view>
            </picker>
          </view>
          <view class="form-row-divider"></view>
          <view class="form-row">
            <text class="f-label">宝宝性别</text>
            <view class="f-pills">
              <view class="pill-btn {{babyGender === 'boy' ? 'pill-on' : ''}}" bindtap="onGenderTap" data-gender="boy">👦 男宝</view>
              <view class="pill-btn {{babyGender === 'girl' ? 'pill-on' : ''}}" bindtap="onGenderTap" data-gender="girl">👧 女宝</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 症状描述卡 -->
      <view class="form-card card-float animate-fade-up" style="animation-delay: 0.14s">
        <view class="card-head">
          <view class="head-icon-bg" style="background:var(--color-primary-bg)">
            <text class="head-icon">📝</text>
          </view>
          <text class="head-title">{{isReviewMode ? '备注信息（选填）' : '症状描述（选填）'}}</text>
        </view>
        <view class="other-symptom-box">
          <textarea class="sym-textarea" placeholder="{{isReviewMode ? '例如：今天状态、饮食情况、作息表现…' : '例如：夜间睡不安稳、腹泻、发烧、食欲不振…'}}" placeholder-class="sym-placeholder" value="{{otherSymptom}}" bindinput="onOtherSymptomInput" auto-height="{{false}}" fixed="{{true}}" />
        </view>
      </view>

      <!-- 拍照指引 -->
      <view class="guide-box animate-fade-up" style="animation-delay: 0.18s">
        <view class="guide-title">{{reviewConfig.guideTitle}}</view>
        <view class="guide-items">
          <view class="guide-item">
            <view class="guide-dot" style="background:var(--color-eco-bg);color:var(--color-eco-dark)">✓</view>
            <text class="guide-text">{{reviewConfig.guideTips[0]}}</text>
          </view>
          <view class="guide-item">
            <view class="guide-dot" style="background:var(--color-eco-bg);color:var(--color-eco-dark)">✓</view>
            <text class="guide-text">{{reviewConfig.guideTips[1]}}</text>
          </view>
          <view class="guide-item">
            <view class="guide-dot" style="background:var(--color-primary-bg);color:var(--color-primary-dark)">×</view>
            <text class="guide-text">{{reviewConfig.guideTips[2]}}</text>
          </view>
        </view>
      </view>

      <!-- 底部操作 -->
      <view class="action-dock animate-fade-up" style="animation-delay: 0.22s">
        <button class="scan-btn card-press" bindtap="chooseImage">
          <text class="btn-icon">📷</text>
          <text class="btn-text">{{isReviewMode ? '立即拍照记录' : '立即拍舌象'}}</text>
        </button>
        <view class="history-link-wrap" bindtap="goToHistory">
          <text class="history-link">{{historyText}}</text>
        </view>
      </view>
    </block>

    <!-- preview 状态 -->
    <block wx:if="{{state === 'preview'}}">
      <view class="preview-card card-float animate-fade-up">
        <view class="preview-frame">
          <image class="preview-img" src="{{selectedImage}}" mode="aspectFill"></image>
          <view class="scanning-laser"></view>
          <view class="scanner-corner tc-tl"></view>
          <view class="scanner-corner tc-tr"></view>
          <view class="scanner-corner tc-bl"></view>
          <view class="scanner-corner tc-br"></view>
        </view>
        <view class="preview-dock">
          <view class="prev-btn btn-ghost card-press" bindtap="retakePhoto">重新拍摄</view>
          <view class="prev-btn btn-primary card-press" bindtap="startAnalyze">{{primaryActionText}}</view>
        </view>
      </view>
    </block>

    <!-- analyzing 状态 -->
    <block wx:if="{{state === 'analyzing'}}">
      <view class="analyzing-state animate-fade-up">
        <view class="ai-brain-loader">
          <view class="circle c1"></view>
          <view class="circle c2"></view>
          <view class="circle c3"></view>
          <view class="core-icon">🌿</view>
        </view>
        <text class="analyzing-title">{{analyzingTitle}}</text>
        <text class="analyzing-sub">{{analyzingSubtitle}}</text>
      </view>
    </block>
  </view>

  <view class="modal-mask {{showLoginModal ? 'modal-show' : ''}}" bindtap="closeLoginModal" wx:if="{{showLoginModal}}">
    <view class="modal-content tongue-auth-modal content-show" catchtap>
      <view class="modal-close-round" bindtap="closeLoginModal">✕</view>

      <view class="auth-header-visual">
        <view class="floating-icon">{{isReviewMode ? '👶' : '🌿'}}</view>
      </view>

      <view class="auth-body">
        <text class="auth-m-title">{{isReviewMode ? '登录后记录宝宝日常' : '登录后使用 AI 舌象'}}</text>
        <text class="auth-m-desc">{{isReviewMode ? '授权手机号后，可保存宝宝日常照片记录并查看历史。' : '授权手机号后，可拍照分析并查看历史舌象报告。'}}</text>

        <block wx:if="{{!privacyChecked}}">
          <view class="auth-privacy-box auth-privacy-loading">
            <text class="auth-privacy-title">正在检查隐私授权状态…</text>
            <text class="auth-privacy-desc">首次使用手机号登录前，需要先确认微信侧的隐私授权状态。</text>
          </view>
        </block>
        <block wx:elif="{{needPrivacyAuthorization}}">
          <view class="auth-privacy-box">
            <text class="auth-privacy-title">使用前请先阅读并同意隐私指引</text>
            <text class="auth-privacy-desc">首次使用当前功能前，请先查看并同意{{privacyContractName}}。</text>

            <button class="tongue-privacy-link" bindtap="openPrivacyContract">查看{{privacyContractName}}</button>
            <button
              id="tongue-privacy-agree-btn"
              class="tongue-privacy-agree"
              open-type="agreePrivacyAuthorization"
              bindagreeprivacyauthorization="onAgreePrivacyAuthorization"
            >
              同意隐私指引
            </button>
          </view>
        </block>
        <button
          wx:else
          class="tongue-login-action"
          open-type="getPhoneNumber"
          bind:getphonenumber="onGetPhoneNumber"
          loading="{{loggingIn}}"
        >
          {{loggingIn ? '登录中...' : '授权手机号安全登录'}}
        </button>

        <view class="auth-safe-tip">
          <text class="safe-icon">🔒</text>
          <text>仅用于同步会员身份、历史记录与订单信息</text>
        </view>
      </view>
    </view>
  </view>
</view>
