/* pages/tongue/tongue.wxss — 统一首页风格 */
.page-container {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg-page);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部背景装饰 (同首页) */
.bg-decoration {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.5;
  z-index: 0;
}
.shape-1 {
  width: 500rpx; height: 500rpx;
  background: var(--color-ai-bg);
  top: -150rpx; right: -100rpx;
  opacity: 0.8;
}
.shape-2 {
  width: 400rpx; height: 400rpx;
  background: var(--color-eco-bg);
  top: 400rpx; left: -150rpx;
  opacity: 0.8;
}

/* 内容区 */
.content-wrapper {
  position: relative;
  z-index: 1;
  padding: 0 var(--spacing-lg);
}

/* 头部 */
.header-area {
  padding: 60rpx 0 var(--spacing-xl);
  text-align: left;
}
.page-main-title {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--color-text-title);
  display: block;
  letter-spacing: -1rpx;
}
.page-sub-title {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  margin-top: var(--spacing-xs);
  display: block;
}

/* 卡片内部间距微调 */
.premium-card {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}
.card-head {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}
.head-icon-bg {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-base);
  margin-right: var(--spacing-sm);
}
.blue-bg { background: rgba(123, 175, 142, 0.15); } /* eco色调 */
.purple-bg { background: var(--color-ai-bg); }
.head-title {
  font-size: var(--font-md);
  font-weight: 800;
  color: var(--color-text-title);
  letter-spacing: 1rpx;
}
.head-hint {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-left: var(--spacing-xs);
}

/* 表单行 */
.form-body {
  display: flex;
  flex-direction: column;
}
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.form-row-divider {
  height: 1rpx;
  background: rgba(0,0,0,0.03);
  margin: var(--spacing-md) 0;
}
.f-label {
  font-size: var(--font-base);
  color: var(--color-text-main);
  font-weight: 600;
}

/* 年龄下拉框 */
.age-picker-box {
  background: #F5F0E8;
  border: 1rpx solid #E5E7EB;
  border-radius: var(--radius-sm);
  padding: var(--spacing-xs) var(--spacing-md);
}
.f-picker {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}
.f-picker-text {
  font-size: var(--font-md);
  font-weight: 700;
  color: #111827;
}
.f-picker-ph {
  color: #9CA3AF;
  font-weight: 400;
}
.f-picker-arrow {
  font-size: var(--font-sm);
  color: #9CA3AF;
  margin-left: 4rpx;
}

/* 性别按钮 */
.f-pills {
  display: flex;
  gap: var(--spacing-sm);
}
.pill-btn {
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-sm);
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-sub);
  background: var(--bg-page);
  border: 1rpx solid rgba(0,0,0,0.05);
  transition: all 0.2s;
}
.pill-btn.boy-on {
  background: var(--color-eco-bg);
  border-color: rgba(123, 175, 142, 0.3);
  color: #059669;
}
.pill-btn.girl-on {
  background: var(--color-primary-bg);
  border-color: rgba(192, 139, 92, 0.2);
  color: var(--color-primary);
}

/* 其他症状输入框 */
.other-symptom-box {
  margin-bottom: var(--spacing-md);
}
.sym-textarea {
  width: 100%;
  height: 160rpx;
  background: #F5F0E8;
  border: 1px solid #E5E7EB;
  border-radius: var(--radius-sm);
  padding: var(--spacing-md);
  font-size: var(--font-sm);
  color: #111827;
  box-sizing: border-box;
  line-height: 1.5;
}

/* 症状横向滚动条 (放置在底部) */
.symptom-scroll {
  display: flex;
  white-space: nowrap;
  overflow-x: auto;
  gap: var(--spacing-sm);
  padding-bottom: 4rpx;
  align-items: center;
}
.symptom-scroll::-webkit-scrollbar {
  display: none;
}
.sym-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  height: 60rpx;
  padding: 0 var(--spacing-lg);
  border-radius: var(--radius-capsule);
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--color-text-main);
  background: var(--bg-page);
  border: 1rpx solid rgba(0,0,0,0.05);
  transition: all 0.2s;
  box-sizing: border-box;
  white-space: nowrap;
}
.sym-tag.sym-on {
  background: var(--color-ai-bg);
  border-color: rgba(107, 138, 153, 0.2);
  color: var(--color-ai);
  font-weight: 600;
}

/* 拍照指引条 */
.guide-strip {
  display: flex;
  justify-content: space-around;
  padding: var(--spacing-md) 0;
  margin-bottom: var(--spacing-md);
}
.g-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}
.icon-circle {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 800;
}
.check-circle { background: var(--color-eco-bg); color: #059669; }
.cross-circle { background: var(--color-primary-bg); color: var(--color-primary); }
.g-text {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  font-weight: 500;
}

/* 大按钮停靠区 */
.action-dock {
  margin-top: var(--spacing-xl);
  padding-bottom: 60rpx;
  text-align: center;
}
.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, var(--color-ai-light), var(--color-ai));
  color: #fff;
  border: none;
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-ai);
}
.scan-btn:active {
  transform: scale(0.97);
  box-shadow: 0 8rpx 16rpx -4rpx rgba(107,138,153,0.3);
}
.btn-icon { font-size: var(--font-lg); }
.btn-text { font-size: var(--font-md); font-weight: 800; letter-spacing: 2rpx; }

.history-link-wrap { display: inline-block; padding: var(--spacing-xs) var(--spacing-lg); }
.history-link { font-size: var(--font-sm); color: var(--color-text-sub); font-weight: 500; text-decoration: underline; }

/* 预览卡片 */
.preview-card {
  margin-top: var(--spacing-md);
  padding: var(--spacing-md);
}
.preview-frame {
  position: relative;
  width: 100%;
  height: 600rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: #000;
}
.preview-img { width: 100%; height: 100%; }
.scanning-laser {
  position: absolute;
  top: 0; left: 0; right: 0; height: 100%;
  background: linear-gradient(to bottom, transparent, rgba(107,138,153,0.2) 50%, var(--color-ai) 50%, transparent);
  background-size: 100% 8rpx;
  animation: laserScan 2.5s infinite linear;
}
@keyframes laserScan {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100%); }
}

/* 扫描框四个角落 */
.scanner-corner { position: absolute; width: 40rpx; height: 40rpx; border: 4rpx solid var(--color-ai); }
.tc-tl { top: 20rpx; left: 20rpx; border-right: none; border-bottom: none; border-radius: var(--radius-sm) 0 0 0;}
.tc-tr { top: 20rpx; right: 20rpx; border-left: none; border-bottom: none; border-radius: 0 var(--radius-sm) 0 0;}
.tc-bl { bottom: 20rpx; left: 20rpx; border-right: none; border-top: none; border-radius: 0 0 0 var(--radius-sm);}
.tc-br { bottom: 20rpx; right: 20rpx; border-left: none; border-top: none; border-radius: 0 0 var(--radius-sm) 0;}

.preview-dock {
  display: flex;
  gap: var(--spacing-md);
  margin-top: var(--spacing-md);
}
.prev-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-capsule);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-base);
  font-weight: 700;
}
.btn-light {
  background: var(--bg-page);
  color: var(--color-text-main);
  border: 1rpx solid rgba(0,0,0,0.05);
}
.btn-brand {
  background: linear-gradient(135deg, var(--color-ai-light), var(--color-ai));
  color: #fff;
  box-shadow: var(--shadow-ai);
}

/* 分析中状态 */
.analyzing-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.ai-brain-loader {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.circle {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid var(--color-ai);
  opacity: 0;
}
.c1 { width: 100rpx; height: 100rpx; animation: brainPulse 2s infinite cubic-bezier(0.2, 0.8, 0.2, 1); }
.c2 { width: 100rpx; height: 100rpx; animation: brainPulse 2s infinite cubic-bezier(0.2, 0.8, 0.2, 1) 0.6s; }
.c3 { width: 100rpx; height: 100rpx; animation: brainPulse 2s infinite cubic-bezier(0.2, 0.8, 0.2, 1) 1.2s; }

@keyframes brainPulse {
  0% { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(3.5); opacity: 0; border-width: 0; }
}

.core-icon {
  font-size: 64rpx;
  position: relative;
  z-index: 2;
  animation: float 3s infinite ease-in-out;
}
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.analyzing-title {
  font-size: var(--font-lg);
  font-weight: 800;
  color: var(--color-text-title);
  margin-top: 60rpx;
  letter-spacing: 2rpx;
}
.analyzing-sub {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  margin-top: var(--spacing-xs);
}
